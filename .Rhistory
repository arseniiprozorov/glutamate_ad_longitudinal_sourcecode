t1_cortical_thickness_dickson, t2_cortical_thickness_dickson, thickness_difference,
t1_hipp_e_tiv, t2_hipp_e_tiv, hipp_difference,
# Activation
hippocampus_avg_activation_t1, hippocampus_avg_activation_t2, hipp_diff_activation,
parietal_sup_l_average_t1, parietal_sup_l_average_t2, parietal_sup_l_diff,
precuneus_t1_avg_act, precuneus_t2_avg_act, precuneus_diff,
acc_t1_avg_activation, acc_t2_avg_activation, acc_diff, slope_moca_raw
)
# 2. Compute correlation matrix and p-values
cor_matrix <- cor(vars_to_correlate, use = "pairwise.complete.obs", method = "pearson")
p_matrix <- cor.mtest(vars_to_correlate, conf.level = 0.95)$p
# 3. Visualize with Automatic Clustering (hclust) and Crosses
corrplot(cor_matrix,
method = "color",
order = "hclust",         # Automatically clusters variables
hclust.method = "ward.D", # Ward's method minimizes variance within clusters
addrect = 4,              # Draws boxes around the 4 main clusters
p.mat = p_matrix,
sig.level = 0.05,
insig = "pch",            # Adds a cross for p > 0.05
pch.col = "gray40",
pch.cex = 1.2,
tl.col = "black",
tl.cex = 0.65,            # Adjusted text size
tl.srt = 45,
diag = FALSE)
