# 2) Structural-only *linear* mediation model (no quadratic direct path)
sem_linear_model_acc <- 't2_hipp_e_tiv ~ t1_glu_acc_c
# 2) Structural-only *linear* mediation model (no quadratic direct path)
sem_linear_model_acc <- 't2_hipp_e_tiv ~ t1_glu_acc_c
slope_moca_scaled ~ t1_glu_acc_c + t2_hipp_e_tiv'
# 3) Fit with FIML + robust SEs
fit_sem_lin_acc <- sem(sem_linear_model_acc,data = MRS_long, missing = "fiml",
fixed.x   = FALSE, estimator = "MLR")
summary(fit_sem_lin_acc, standardized = TRUE, ci = TRUE)
parameterEstimates(fit_sem_lin_acc, standardized = TRUE, ci = TRUE)
pe <- parameterEstimates(fit_sem_lin_acc)
a_hat <- pe$est[pe$lhs=="t2_hipp_e_tiv" & pe$op=="~" & pe$rhs=="t1_glu_acc_c"]
b_hat <- pe$est[pe$lhs=="slope_moca_scaled" & pe$op=="~" & pe$rhs=="t2_hipp_e_tiv"]
ind_hat <- a_hat * b_hat
ind_hat
set.seed(1)
# coefficient vector and vcov from the fitted model
cf <- coef(fit_sem_lin_acc)
V  <- vcov(fit_sem_lin_acc)
# Find which coefficients correspond to the a and b paths
# (names(cf) shows lavaan's internal parameter names)
names(cf)
idx_a <- grep("^t2_hipp_e_tiv~t1_glu_acc_c$", names(cf))
idx_b <- grep("^slope_moca_scaled~t2_hipp_e_tiv$", names(cf))
mu <- c(cf[idx_a], cf[idx_b])
Sigma <- V[c(idx_a, idx_b), c(idx_a, idx_b)]
# Draw from asymptotic sampling distribution of (a,b)
S <- 50000
draws <- MASS::mvrnorm(S, mu = mu, Sigma = Sigma)
ind_draw <- draws[,1] * draws[,2]
c(
indirect_est = ind_hat,
CI_2.5 = quantile(ind_draw, 0.025),
CI_50  = quantile(ind_draw, 0.50),
CI_97.5= quantile(ind_draw, 0.975)
)
