# 1. Re-create the specific table you want to plot (ensure Decliners are columns)
# For standard Mosaic Plots, it's often better to have the Outcome as the vertical dimension.
acc_table_plot <- table(MRS_long$decliners, MRS_long$traj_glu_acc)
# 2. Add clearer labels to your table factors so the plot is self-explanatory
dimnames(acc_table_plot) <- list(
Clinical_Status = c("Stable (0)", "Declining (1)"),
ACC_Glu_Trajectory = c("Decreasing", "Increasing")
)
# 3. Generate the customized, shaded Mosaic Plot
mosaic(acc_table_plot,
shade = TRUE, # This turns on the color shading based on stdres
legend = TRUE, # Shows the color key for the Z-scores
gp = gpar(fill = c("grey", "deepskyblue", "tomato")), # Optional: customize colors
labeling = labeling_border(rot_labels = c(0, 0, 0, 0), pos_varnames = c("top", "left")),
main = "Metabolic Signature of Cognitive Decline",
sub = "Color shading indicates Z-score significance derived from Adjusted Standardized Residuals",
xlab = "Clinical Outcome (Decliners)",
ylab = "ACC Glutamate Trajectory")
# 1. Ensure the table has the right labels
acc_table_plot <- table(MRS_long$traj_glu_acc, MRS_long$decliners)
dimnames(acc_table_plot) <- list(
ACC_Trajectory = c("Decreasing", "Increasing"),
Outcome = c("Stable", "Declining")
)
# 2. The Fixed Mosaic Command
# We use 'shading_Friendly' to get the standard Blue/Red significance colors
mosaic(acc_table_plot,
shade = TRUE,
legend = TRUE,
main = "Metabolic Signature of Cognitive Decline",
labeling = labeling_residuals)
