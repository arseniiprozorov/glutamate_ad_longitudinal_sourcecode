install.packages("ppcor")
library(ppcor)
# 1. Define your variables
baseline_glu <- "t1_glu_prec"
change_structure <- "thickness_difference" # Rate of Change in B
baseline_structure <- "t1_cortical_thickness_dickson" # Baseline B
change_glu <- "percent_change_glu_prec" # Rate of Change in A
# 2. Run the three "Villain" models
# Model 1: The Sequential Path (Baseline A -> Rate of Change B)
mod1 <- lm(as.formula(paste(change_structure, "~", baseline_glu, "+ t1_age + sexe")), data = MRS_long)
# Model 2: The Reverse Path (Rate of Change A -> Baseline B)
mod2 <- lm(as.formula(paste(baseline_structure, "~", change_glu, "+ t1_age + sexe")), data = MRS_long)
# Model 3: The Cross-sectional Path (Baseline A -> Baseline B)
mod3 <- lm(as.formula(paste(baseline_structure, "~", baseline_glu, "+ t1_age + sexe")), data = MRS_long)
# 3. Extract and compare Partial Correlations (r)
library(ppcor) # If you want pure partial correlations
p_corr1 <- pcor.test(MRS_long[[baseline_glu]], MRS_long[[change_structure]], MRS_long[, c("t1_age")])
# 1. Create a clean subset for the Sequential Path
clean_seq <- na.omit(MRS_long[, c(baseline_glu, change_structure, "t1_age", "sexe")])
p_corr1 <- pcor.test(
x = clean_seq[[baseline_glu]],
y = clean_seq[[change_structure]],
z = clean_seq[, c("t1_age", "sexe")]
)
# 1. Create a truly numeric version of your data subset
clean_seq <- na.omit(MRS_long[, c(baseline_glu, change_structure, "t1_age", "sexe")])
# Convert 'sexe' to numeric (e.g., 1 and 2) so ppcor can handle it
clean_seq$sexe_num <- as.numeric(as.factor(clean_seq$sexe))
# 2. Run the Sequential Path
p_corr1 <- pcor.test(
x = as.numeric(clean_seq[[baseline_glu]]),
y = as.numeric(clean_seq[[change_structure]]),
z = clean_seq[, c("t1_age", "sexe_num")] # Only numeric columns here!
)
# 3. Repeat for the Reverse Path
clean_rev <- na.omit(MRS_long[, c(change_glu, baseline_structure, "t1_age", "sexe")])
clean_rev$sexe_num <- as.numeric(as.factor(clean_rev$sexe))
p_corr2 <- pcor.test(
x = as.numeric(clean_rev[[change_glu]]),
y = as.numeric(clean_rev[[baseline_structure]]),
z = clean_rev[, c("t1_age", "sexe_num")]
)
# 4. Results
print(paste("Sequential r:", round(p_corr1$estimate, 3), "p:", round(p_corr1$p.value, 3)))
print(paste("Reverse r:", round(p_corr2$estimate, 3), "p:", round(p_corr2$p.value, 3)))
