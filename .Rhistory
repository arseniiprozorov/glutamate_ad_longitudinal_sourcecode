library(arm)
library(pROC)
# Define the shared covariates string
covariates <- " + initiale_age + sexe + education + diagnostic_nick"
# Define your 11 model combinations (predictors only)
# We will combine these with the 'decliners' outcome and the 'covariates'
model_formulas <- c(
"decliners ~ plasma_ptau217_z + m_m_acc_z",                       # 1
"decliners ~ plasma_ptau217_z + m_m_precuneus_z",                 # 2
"decliners ~ m_m_precuneus_z + cortical_thickness_adsignature_dickson_z", # 7
"decliners ~ m_m_acc_z + cortical_thickness_adsignature_dickson_z",       # 8
"decliners ~ m_m_precuneus_z + hipp_mean_z",                      # 9
"decliners ~ m_m_acc_z + hipp_mean_z",                            # 10
"decliners ~ m_m_precuneus_z + activation_parietal_sup_l_z",      # 3
"decliners ~ m_m_acc_z + activation_parietal_sup_l_z",            # 4
"decliners ~ m_m_precuneus_z + hipp_mean_act_z",                  # 5
"decliners ~ m_m_acc_z + hipp_mean_act_z",                        # 6
"decliners ~ m_m_precuneus_z + m_m_acc_z"                         # 11
)
# Loop through all models
results_list <- list()
for (f in model_formulas) {
full_formula <- paste0(f, covariates)
# Run the Robust Bayesian Model
fit <- bayesglm(as.formula(full_formula), data = MRS_prediction, family = binomial(link = "logit"))
# Extract metrics
probs <- predict(fit, type = "response")
actuals <- model.frame(fit)$decliners
roc_obj <- roc(actuals, probs, quiet = TRUE)
# Store results
results_list[[f]] <- list(
model = summary(fit),
auc = auc(roc_obj),
youden = coords(roc_obj, "best", ret=c("threshold", "specificity", "sensitivity"), best.method="youden")
)
# Print progress
cat("--------------------------------------------------\n")
cat("Model:", f, "\n")
cat("AUC:", round(as.numeric(auc(roc_obj)), 4), "\n")
print(coords(roc_obj, "best", ret=c("threshold", "specificity", "sensitivity"), best.method="youden"))
}
library(arm)
