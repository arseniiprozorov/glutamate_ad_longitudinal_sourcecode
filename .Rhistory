# 1. Load the required validation packages
library(caret)
library(pROC)
# 2. Isolate the exact complete cases for the new 4-predictor model
# We must include the new tau_gap_years variable in this list
cv_vars_adjusted <- c("decliners", "plasma_ptau217", "t1_glu_acc", "parietal_sup_l_average_t1", "tau_gap_years")
cv_data_adjusted <- na.omit(MRS_long[, cv_vars_adjusted])
# 3. Format 'decliners' as a proper factor for classification metric evaluation
cv_data_adjusted$decliners <- factor(
ifelse(cv_data_adjusted$decliners == 1, "Decliner", "Stable"),
levels = c("Decliner", "Stable")
)
# 4. Set up the Repeated 5-Fold Cross-Validation structure
set.seed(123) # Lock seed so the folds are identical to your last test
cv_control_adjusted <- trainControl(
method = "repeatedcv",
number = 5,
repeats = 10,
classProbs = TRUE,
summaryFunction = twoClassSummary
)
# 5. Train and validate the gap-adjusted model
cv_model_adjusted <- train(
decliners ~ plasma_ptau217 + t1_glu_acc + parietal_sup_l_average_t1 + tau_gap_years,
data = cv_data_adjusted,
method = "glm",
family = "binomial",
trControl = cv_control_adjusted,
metric = "ROC"
)
# 6. Print the cross-validation results
print(cv_model_adjusted)
library(pROC)
library(dplyr) # For sorting and binding the final table
# 1. Define your candidate baseline variables
candidate_vars <- c(
"plasma_ptau217",
"t1_glu_prec",
"t1_glu_acc",
"t1_hipp_e_tiv",
"t1_cortical_thickness_dickson",
"hippocampus_l_average_t1",
"parietal_sup_l_average_t1"
)
# 2. Create an empty list to store the results
results_list <- list()
counter <- 1
# 3. Loop through 1, 2, and 3 variable combinations
for (k in 1:3) {
# Generate all unique combinations of size 'k'
combos <- combn(candidate_vars, k, simplify = FALSE)
for (vars in combos) {
# Construct the formula string (e.g., "decliners ~ plasma_ptau217 + t1_glu_acc")
formula_str <- paste("decliners ~", paste(vars, collapse = " + "))
# Use tryCatch to prevent the loop from crashing if a specific model fails to converge
tryCatch({
# Fit the logistic regression model
model <- glm(as.formula(formula_str), data = MRS_long, family = "binomial")
# Calculate ROC and AUC (quiet = TRUE suppresses the console spam)
model_roc <- roc(model$y, fitted(model), quiet = TRUE)
model_auc <- as.numeric(auc(model_roc))
# Extract Youden threshold metrics
best_coords <- coords(model_roc, "best", ret = c("threshold", "specificity", "sensitivity"), best.method = "youden")
# If multiple thresholds tie for 'best', take the first one to avoid formatting errors
if(is.matrix(best_coords) || is.data.frame(best_coords)){
best_coords <- best_coords[1, ]
}
# Store the results in a dataframe format
results_list[[counter]] <- data.frame(
Num_Vars = k,
Variables = paste(vars, collapse = " + "),
AUC = round(model_auc, 4),
Sensitivity = round(as.numeric(best_coords["sensitivity"]), 4),
Specificity = round(as.numeric(best_coords["specificity"]), 4),
Threshold = round(as.numeric(best_coords["threshold"]), 4),
N_used = length(model$y) # Critical: Tracks how many participants had complete data for this combo
)
counter <- counter + 1
}, error = function(e) {
# If a combination fails due to missing data or perfect separation, skip silently
})
}
}
# 4. Combine all results into a single table and sort by highest AUC
master_model_table <- bind_rows(results_list) %>%
arrange(desc(AUC))
# 5. View your top 15 best-performing models
head(master_model_table, 15)
