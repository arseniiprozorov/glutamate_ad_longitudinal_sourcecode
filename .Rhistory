# Step 3: Run the Core Sequence Models (Testing for Quadratic Effects)
# ---------------------------------------------------------
# --- 1. Does Pre-disease Structure Quadratically Predict T0 Glutamate? ---
# Cortical Thickness predicting Glutamate
summary(lm(glu_precuneus_T_0 ~ norm_cortical_thickness_dickerson_T_Pre +
I(norm_cortical_thickness_dickerson_T_Pre^2), data = binned_cascade))
