## fMRI Activation Variables
MRS_long$parietal_sup_l_average_t1 <- winsorize_iqr(MRS_long$parietal_sup_l_average_t1, 1.5)
MRS_long$parietal_sup_l_average_t2 <- winsorize_iqr(MRS_long$parietal_sup_l_average_t2, 1.5)
