# Total N in dataset (rows)
N_total <- nrow(MRS_long)
# N used for a-path (X and M present)
N_a <- sum(complete.cases(MRS_long[, c("t1_glu_acc_c", "t2_hipp_e_tiv")]))
# N used for outcome regression (Y, X, and M present)
N_bcp <- sum(complete.cases(MRS_long[, c("slope_moca_scaled", "t1_glu_acc_c", "t2_hipp_e_tiv")]))
# (optional) pairwise counts, if you want them
N_XY <- sum(complete.cases(MRS_long[, c("t1_glu_acc_c", "slope_moca_scaled")]))
N_MY <- sum(complete.cases(MRS_long[, c("t2_hipp_e_tiv", "slope_moca_scaled")]))
c(
N_total = N_total,
N_a_path_XM = N_a,
N_outcome_reg_YXM = N_bcp,
N_pairwise_XY = N_XY,
N_pairwise_MY = N_MY
)
