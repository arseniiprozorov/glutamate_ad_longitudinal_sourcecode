library(caret)
library(dplyr)
# 1. Define your candidate baseline variables
candidate_vars <- c(
"plasma_ptau217",
"t1_glu_prec",
"t1_glu_acc",
"t1_hipp_e_tiv",
"t1_cortical_thickness_dickson",
"hippocampus_l_average_t1",
"parietal_sup_l_average_t1"
)
# 2. Set up the Repeated 5-Fold Cross-Validation structure
set.seed(123) # Lock the seed so folds are strictly comparable across all models
cv_control <- trainControl(
method = "repeatedcv",
number = 5,
repeats = 10,
classProbs = TRUE,
summaryFunction = twoClassSummary
)
# 3. Create an empty list to store the results
results_list_cv <- list()
counter <- 1
# 4. Loop through 1, 2, and 3 variable combinations
for (k in 1:3) {
combos <- combn(candidate_vars, k, simplify = FALSE)
for (vars in combos) {
# Isolate the exact variables needed for this specific loop
# This is crucial so we only drop participants missing THESE specific variables
model_vars <- c("decliners", vars)
cv_data <- na.omit(MRS_long[, model_vars])
# caret requires the outcome to be a factor with valid text levels (not 0/1)
cv_data$decliners <- factor(
ifelse(cv_data$decliners == 1, "Decliner", "Stable"),
levels = c("Decliner", "Stable")
)
formula_str <- paste("decliners ~", paste(vars, collapse = " + "))
# tryCatch prevents the loop from breaking if a small fold has perfect separation
tryCatch({
# Train and cross-validate the model
cv_model <- train(
as.formula(formula_str),
data = cv_data,
method = "glm",
family = "binomial",
trControl = cv_control,
metric = "ROC"
)
# Extract the cross-validated metrics (averaged across all 50 resamples)
cv_results <- cv_model$results
# Store the results
results_list_cv[[counter]] <- data.frame(
Num_Vars = k,
Variables = paste(vars, collapse = " + "),
CV_AUC = round(cv_results$ROC, 4),
CV_Sensitivity = round(cv_results$Sens, 4),
CV_Specificity = round(cv_results$Spec, 4),
N_used = nrow(cv_data) # Tracks exact sample size for this combo
)
counter <- counter + 1
}, error = function(e) {
# Fails silently if a specific combo breaks the math in a fold, moves to next
})
}
}
# 5. Combine all results into a single table and sort by highest Cross-Validated AUC
master_cv_table <- bind_rows(results_list_cv) %>%
arrange(desc(CV_AUC))
# 6. View your true top 15 most robust predictive models
head(master_cv_table, 15)
model_tau_hipp_vol <- glm(decliners ~ plasma_ptau217 + t1_hipp_e_tiv + parietal_sup_l_average_t1, data = MRS_long, family = "binomial")
summary(model_tau_hipp_vol)
roc_tau_hipp_vol <- roc(model_tau_hipp_vol$y, fitted(model_tau_hipp_vol))
auc(roc_tau_hipp_vol)
coords(roc_tau_hipp_vol, "best", ret=c("threshold", "specificity", "sensitivity"), best.method="youden")
