library(pROC)
# 1. Define your 6 base predictor variables
predictors <- c(
"t1_glu_prec",
"t1_glu_acc",
"t1_hipp_e_tiv",
"t1_cortical_thickness_dickson",
"hippocampus_l_average_t1",
"parietal_sup_l_average_t1"
)
# 2. Generate all combinations (1-way, 2-way, and 3-way)
comb_1 <- combn(predictors, 1, simplify = FALSE)
comb_2 <- combn(predictors, 2, simplify = FALSE)
comb_3 <- combn(predictors, 3, simplify = FALSE)
all_combs <- c(comb_1, comb_2, comb_3)
# 3. Create a list of formulas and name them
formula_strings <- sapply(all_combs, function(vars) {
paste("decliners ~", paste(vars, collapse = " + "))
})
names(formula_strings) <- sapply(all_combs, function(vars) {
paste(vars, collapse = " + ")
})
# 4. Define the LOOCV function
get_loocv_metrics <- function(f_string, data) {
# A. Extract the variables needed for this specific formula
vars_needed <- all.vars(as.formula(f_string))
# B. Filter the dataset to only include people with NO missing data for these variables
# This perfectly matches what the standard GLM was doing automatically
df_clean <- na.omit(data[, vars_needed])
n_samples <- nrow(df_clean)
out_of_fold_preds <- numeric(n_samples)
# C. The Leave-One-Out Loop
for(i in 1:n_samples) {
# Train the model on everyone EXCEPT participant 'i'
fit <- glm(as.formula(f_string), data = df_clean[-i, ], family = "binomial")
# Predict the probability of decline for the left-out participant 'i'
out_of_fold_preds[i] <- predict(fit, newdata = df_clean[i, , drop=FALSE], type = "response")
}
# D. Calculate the cross-validated ROC using the out-of-fold predictions
roc_obj <- suppressMessages(roc(df_clean$decliners, out_of_fold_preds))
best <- coords(roc_obj, "best", ret=c("threshold", "specificity", "sensitivity"), best.method="youden", transpose=FALSE)
# E. Return the cross-validated metrics
data.frame(
CV_AUC      = round(as.numeric(auc(roc_obj)), 3),
CV_Sens     = round(as.numeric(best$sensitivity[1]), 3),
CV_Spec     = round(as.numeric(best$specificity[1]), 3),
N_Decliners = sum(df_clean$decliners == 1), # Good to track to see sample size
Total_N     = n_samples
)
}
# 5. Apply function, combine into table, and SORT by CV_AUC
# Note: We loop over the names(formula_strings) now so we can pass the string to the function
cv_results_list <- lapply(formula_strings, function(f) get_loocv_metrics(f, MRS_long))
cv_results_table <- do.call(rbind, cv_results_list)
cv_results_table <- cv_results_table[order(-cv_results_table$CV_AUC), ] # Sort highest AUC to lowest
# 6. View the robust results!
print(cv_results_table)
