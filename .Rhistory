names(MRS_long)
library(tidyverse)
# 1. Prepare Left Parietal Data
# Select only the columns needed
parietal_sub <- your_dataframe[, c("pscid", "t1_age", "age_difference",
"parietal_sup_l_average_t1", "parietal_sup_l_average_t2")]
# 1. Create the T1 subset
# We keep pscid, age, and relevant T1 columns
# IMPORTANT: Rename the columns so they have the SAME name in both T1 and T2 datasets
t1_data <- MRS_long[, c("pscid", "t1_age", "age_difference",
"parietal_sup_l_average_t1",
"hippocampus_avg_activation_t1",
"t1_glu_prec", "t1_glu_acc")]
colnames(t1_data) <- c("pscid", "age", "age_diff", "parietal", "hippocampus", "glu_prec", "glu_acc")
t1_data$years_elapsed <- 0  # At T1, years elapsed is 0
# 2. Create the T2 subset
# We keep pscid, age, and relevant T2 columns
t2_data <- MRS_long[, c("pscid", "t1_age", "age_difference",
"parietal_sup_l_average_t2",
"hippocampus_avg_activation_t2",
"t2_glu_prec", "t2_glu_acc")]
colnames(t2_data) <- c("pscid", "age", "age_diff", "parietal", "hippocampus", "glu_prec", "glu_acc")
t2_data$years_elapsed <- t2_data$age_diff # At T2, years elapsed is the age difference
# 3. Stack them together (rbind)
df_long <- rbind(t1_data, t2_data)
# 4. Remove missing data (if someone didn't return for T2)
df_long <- df_long[!is.na(df_long$glu_prec), ]
# 5. Center the time variable (Essential for quadratic models)
df_long$years_elapsed_c <- df_long$years_elapsed - mean(df_long$years_elapsed, na.rm = TRUE)
library(lme4)
library(lmerTest)
lmm_prec_quad <- lmer(glu_prec ~ years_elapsed_c + I(years_elapsed_c^2) + age +
(1 | pscid),
data = df_long)
summary(lmm_prec_quad)
lmm_acc_quad <- lmer(glu_acc ~ years_elapsed_c + I(years_elapsed_c^2) + age +
(1 | pscid),
data = df_long)
summary(lmm_acc_quad)
lmm_parietal_quad <- lmer(parietal ~ years_elapsed_c + I(years_elapsed_c^2) + age +
(1 | pscid),
data = df_long)
summary(lmm_parietal_quad)
