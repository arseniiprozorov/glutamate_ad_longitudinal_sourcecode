# Load required packages
library(ggplot2)
library(tidyr)
library(dplyr)
# 1. Reshape the data from Wide to Long format
MRS_anova_data <- MRS_long %>%
# Keep only the columns we need
select(pscid, decliners, percent_change_glu_acc, percent_change_glu_prec) %>%
# Pivot the ACC and Precuneus columns into a single "percent_change" column
pivot_longer(
cols = c(percent_change_glu_acc, percent_change_glu_prec),
names_to = "region",
values_to = "percent_change"
) %>%
# Clean up the region names so they look nice on the plot
mutate(
region = ifelse(grepl("acc", region), "ACC", "Precuneus"),
region = as.factor(region)
)
# 2. Visualize the Two-Way ANOVA (Interaction Plot)
ggplot(MRS_anova_data, aes(x = region, y = percent_change, fill = decliners)) +
# Add boxplots to show the spread of the data
geom_boxplot(alpha = 0.5, outlier.shape = NA) +
# Add points for the means
stat_summary(fun = mean, geom = "point", shape = 18, size = 4,
position = position_dodge(0.75), aes(color = decliners)) +
# Add lines connecting the means to visualize the INTERACTION
stat_summary(fun = mean, geom = "line", aes(group = decliners, color = decliners),
position = position_dodge(0.75), linewidth = 1) +
theme_minimal() +
labs(
title = "Glutamate Trajectories: Decliners vs. Non-Decliners by Region",
x = "Brain Region",
y = "Percentage Change in Glutamate",
fill = "Decline Status",
color = "Decline Status"
) +
theme(legend.position = "bottom")
# 3. Run the Statistical Two-Way ANOVA Model
# The asterisk (*) tests for Main Effect of Decliners, Main Effect of Region, AND the Interaction
anova_model <- aov(percent_change ~ decliners * region, data = MRS_anova_data)
summary(anova_model)
# 1. ANOVA for ACC Percentage Change
anova_acc <- aov(percent_change_glu_acc ~ decliners, data = MRS_long)
summary(anova_acc)
# 2. ANOVA for Precuneus Percentage Change
anova_prec <- aov(percent_change_glu_prec ~ decliners, data = MRS_long)
summary(anova_prec)
library(dplyr)
library(tidyr)
# 1. Reshape the data for a 3-Way ANOVA
MRS_3way <- MRS_long %>%
# Keep only ID, group, and the raw T1/T2 raw glutamate columns
select(pscid, decliners, t1_glu_acc, t2_glu_acc, t1_glu_prec, t2_glu_prec) %>%
# Pivot the data so Time and Region become explicit factors
pivot_longer(
cols = starts_with("t"),
names_to = c("time", "region"),
names_pattern = "(t[12])_glu_(.*)", # Extracts "t1"/"t2" and "acc"/"prec"
values_to = "glu_level"
) %>%
# Convert to factors for the ANOVA
mutate(
time = as.factor(time),
region = as.factor(region),
pscid = as.factor(pscid)
)
# 2. Run the 3-Way Mixed ANOVA
# The 'Error(pscid/(time*region))' term tells R this is repeated-measures data
model_3way <- aov(glu_level ~ decliners * time * region + Error(pscid/(time*region)), data = MRS_3way)
# 3. View the Results
summary(model_3way)
# Install these if you haven't already:
# install.packages(c("lme4", "lmerTest"))
library(lme4)
library(lmerTest) # This package is required to calculate p-values for LMMs
# Run the Linear Mixed-Effects Model
# (1 | pscid) tells the model that data is nested within individual participants
model_lme <- lmer(glu_level ~ decliners * time * region + (1 | pscid), data = MRS_3way)
# View the clean ANOVA table of the results
anova(model_lme)
View(MRS_3way)
_lme)
install.packages("sjPlot")
install.packages("sjmisc") # Dependency often needed
library(sjPlot)
# Plot the 3-way interaction directly from your lmer model
plot_model(model_lme,
type = "pred",
terms = c("time", "decliners", "region"),
title = "Predicted Glutamate Trajectories",
axis.title = c("Time", "Estimated Glutamate Level"))
