# 1. Identify all valid numeric test variables (excluding IDs and age/sex)
numeric_vars <- names(MRS_long)[sapply(MRS_long, function(x) is.numeric(as.numeric(x)))]
glu_vars <- c("t1_glu_prec", "t1_glu_acc")
target_vars <- setdiff(numeric_vars, c("pscid", "t1_age", "t2_age", "age_difference", glu_vars))
# Storage list for significant results
quad_mining_results <- list()
# --- BATCH 1: Glutamate as PREDICTOR (Outcome ~ Glu + Glu^2) ---
for (glu in glu_vars) {
# Center glutamate to avoid multicollinearity
centered_glu <- as.numeric(scale(MRS_long[[glu]], center = TRUE, scale = FALSE))
for (out in target_vars) {
form <- as.formula(paste(out, "~ centered_glu + I(centered_glu^2) + t1_age + sexe"))
fit <- try(lm(form, data = MRS_long), silent = TRUE)
if (!inherits(fit, "try-error")) {
summ <- summary(fit)$coefficients
# Check if quadratic term exists and is significant
if ("I(centered_glu^2)" %in% rownames(summ)) {
p_val <- summ["I(centered_glu^2)", "Pr(>|t|)"]
if (p_val < 0.05) {
res <- as.data.frame(t(summ["I(centered_glu^2)", ]))
res$Model_Type <- "Glu_as_Predictor"
res$X_Var <- glu
res$Y_Var <- out
quad_mining_results[[paste0("P_", glu, "_", out)]] <- res
}
}
}
}
}
# 1. Stricter identification of numeric variables (explicitly excluding factors)
# We use Filter() to ensure we only get the truly numeric columns
numeric_data <- MRS_long[, sapply(MRS_long, is.numeric)]
numeric_vars <- names(numeric_data)
glu_vars <- c("t1_glu_prec", "t1_glu_acc")
# Exclude IDs, ages, and the glutamate variables themselves from the test list
target_vars <- setdiff(numeric_vars, c("pscid", "t1_age", "t2_age", "age_difference", glu_vars))
quad_mining_results <- list()
# --- BATCH 1: Glutamate as PREDICTOR (Outcome ~ Glu + Glu^2) ---
for (glu in glu_vars) {
# as.numeric(as.vector()) ensures we aren't passing a matrix/array to the model
centered_glu <- as.numeric(scale(MRS_long[[glu]], center = TRUE, scale = FALSE))
for (out in target_vars) {
# Using backticks `` around variable names handles any special characters
form <- as.formula(paste0("`", out, "` ~ centered_glu + I(centered_glu^2) + t1_age + sexe"))
fit <- try(lm(form, data = MRS_long), silent = TRUE)
if (!inherits(fit, "try-error")) {
summ <- summary(fit)$coefficients
row_name <- "I(centered_glu^2)"
# Safety check: Does the term exist and is the p-value NOT NA?
if (row_name %in% rownames(summ)) {
p_val <- summ[row_name, "Pr(>|t|)"]
if (!is.na(p_val) && p_val < 0.05) {
res <- as.data.frame(t(summ[row_name, ]))
res$Model_Type <- "Glu_as_Predictor"
res$X_Var <- glu
res$Y_Var <- out
quad_mining_results[[paste0("P_", glu, "_", out)]] <- res
}
}
}
}
}
# --- BATCH 2: Glutamate as OUTCOME (Glu ~ Var + Var^2) ---
for (glu in glu_vars) {
for (pred in target_vars) {
centered_pred <- as.numeric(scale(MRS_long[[pred]], center = TRUE, scale = FALSE))
form <- as.formula(paste0("`", glu, "` ~ centered_pred + I(centered_pred^2) + t1_age + sexe"))
fit <- try(lm(form, data = MRS_long), silent = TRUE)
if (!inherits(fit, "try-error")) {
summ <- summary(fit)$coefficients
row_name <- "I(centered_pred^2)"
if (row_name %in% rownames(summ)) {
p_val <- summ[row_name, "Pr(>|t|)"]
if (!is.na(p_val) && p_val < 0.05) {
res <- as.data.frame(t(summ[row_name, ]))
res$Model_Type <- "Glu_as_Outcome"
res$X_Var <- pred
res$Y_Var <- glu
quad_mining_results[[paste0("O_", glu, "_", pred)]] <- res
}
}
}
}
}
# 3. Combine and View Results
if (length(quad_mining_results) > 0) {
final_mining_table <- do.call(rbind, quad_mining_results)
print(final_mining_table[, c("Model_Type", "X_Var", "Y_Var", "Estimate", "Pr(>|t|)")])
} else {
print("No significant quadratic relationships found.")
}
# 1. Setup variables
numeric_data <- MRS_long[, sapply(MRS_long, is.numeric)]
numeric_vars <- names(numeric_data)
glu_vars <- c("t1_glu_prec", "t1_glu_acc")
# We test how Glu moderates the relationship between these predictors and the MoCA slope
predictors <- setdiff(numeric_vars, c("pscid", "t1_age", "t2_age", "age_difference", "slope_moca_raw", glu_vars))
moderation_results <- list()
for (glu in glu_vars) {
# Center the Moderator (Glutamate)
m_glu <- as.numeric(scale(MRS_long[[glu]], center = TRUE, scale = FALSE))
for (pred in predictors) {
# Center the Independent Variable (e.g., Hippocampus or Thickness)
x_var <- as.numeric(scale(MRS_long[[pred]], center = TRUE, scale = FALSE))
# Formula: Outcome ~ X * Moderator + Controls
# This expands to: Outcome ~ X + Mod + (X:Mod) + Age + Sexe
form <- as.formula(paste0("slope_moca_raw ~ x_var * m_glu + t1_age + sexe"))
fit <- try(lm(form, data = MRS_long), silent = TRUE)
if (!inherits(fit, "try-error")) {
summ <- summary(fit)$coefficients
interaction_term <- "x_var:m_glu"
if (interaction_term %in% rownames(summ)) {
p_val <- summ[interaction_term, "Pr(>|t|)"]
# We only care about cases where the INTERACTION is significant
if (!is.na(p_val) && p_val < 0.05) {
res <- as.data.frame(t(summ[interaction_term, ]))
res$Predictor <- pred
res$Moderator <- glu
res$Term <- interaction_term
moderation_results[[paste0(glu, "_", pred)]] <- res
}
}
}
}
}
# 3. Combine and View Results
if (length(moderation_results) > 0) {
final_moderation_table <- do.call(rbind, moderation_results)
print(final_moderation_table[, c("Predictor", "Moderator", "Estimate", "Pr(>|t|)")])
} else {
print("No significant moderation effects found.")
}
# 1. Prepare centered variables (Crucial for moderation to avoid collinearity)
MRS_long$c_glu_prec <- as.numeric(scale(MRS_long$t1_glu_prec, center = TRUE, scale = FALSE))
MRS_long$c_glu_acc  <- as.numeric(scale(MRS_long$t1_glu_acc, center = TRUE, scale = FALSE))
MRS_long$c_thick    <- as.numeric(scale(MRS_long$t1_cortical_thickness_dickson, center = TRUE, scale = FALSE))
MRS_long$c_hipp     <- as.numeric(scale(MRS_long$t1_hipp_e_tiv, center = TRUE, scale = FALSE))
# 2. Moderation Models
# Model A: Does Precuneus Glutamate moderate the impact of Cortical Thickness?
mod_thick_prec <- lm(slope_moca_raw ~ c_thick * c_glu_prec + t1_age + sexe, data = MRS_long)
summary(mod_thick_prec)
# Model B: Does Precuneus Glutamate moderate the impact of Hippocampal Volume?
mod_hipp_prec <- lm(slope_moca_raw ~ c_hipp * c_glu_prec + t1_age + sexe, data = MRS_long)
summary(mod_hipp_prec)
# Model C: Does ACC Glutamate moderate the impact of Cortical Thickness?
mod_thick_acc <- lm(slope_moca_raw ~ c_thick * c_glu_acc + t1_age + sexe, data = MRS_long)
summary(mod_thick_acc)
# Model D: Does ACC Glutamate moderate the impact of Hippocampal Volume?
mod_hipp_acc <- lm(slope_moca_raw ~ c_hipp * c_glu_acc + t1_age + sexe, data = MRS_long)
summary(mod_hipp_acc)
# install.packages("mediation")
library(mediation)
# --- EXAMPLE: Does Precuneus Glu mediate the effect of Thickness on MoCA? ---
# Path A: The effect of Structure on the Mediator
# Structure (X) -> Glutamate (M)
model_m <- lm(c_glu_prec ~ c_thick + t1_age + sexe, data = MRS_long)
# Path B & C': The effect of the Mediator on the Outcome
# Structure (X) + Glutamate (M) -> MoCA (Y)
model_y <- lm(slope_moca_raw ~ c_glu_prec + c_thick + t1_age + sexe, data = MRS_long)
# Mediation Test (using 1000 bootstrap simulations for robust results)
med_result <- mediate(model_m, model_y, treat = "c_thick", mediator = "c_glu_prec", boot = TRUE, sims = 1000)
summary(med_result)
names(MRS_long)
# 1. Install and load necessary library
if (!require("mediation")) install.packages("mediation")
library(mediation)
# 2. Define your variables
predictors <- c("t1_hipp_e_tiv", "t1_cortical_thickness_dickson")
mediators <- c("t1_glu_prec", "t1_glu_acc")
outcome <- "slope_moca_raw"
mediation_results <- list()
# 3. The Loop
for (pred in predictors) {
for (med in mediators) {
# Path A: Structure -> Glutamate
# (Does atrophy predict glutamate levels?)
med_model <- lm(as.formula(paste0("`", med, "` ~ `", pred, "` + t1_age + sexe")), data = MRS_long)
# Path B & C': Structure + Glutamate -> MoCA Slope
# (Does glutamate predict decline when controlling for atrophy?)
out_model <- lm(as.formula(paste0("`", outcome, "` ~ `", med, "` + `", pred, "` + t1_age + sexe")), data = MRS_long)
# Run Mediation with 1000 bootstrap simulations
# Note: 'treat' is your X, 'mediator' is your M
med_out <- mediate(med_model, out_model,
treat = pred,
mediator = med,
boot = TRUE, sims = 1000)
# Extract results into a clean format
summ <- summary(med_out)
res <- data.frame(
X = pred,
M = med,
ACME_p = summ$d0.p,    # Indirect effect (Mediation)
ADE_p = summ$z0.p,     # Direct effect
Total_p = summ$tau.p,  # Total effect
Prop_Med = summ$n0     # Proportion mediated
)
mediation_results[[paste0(pred, "_", med)]] <- res
}
}
library(mediation)
# 1. Ensure all change variables are clean numeric vectors
MRS_long$slope_moca_raw <- as.numeric(MRS_long$slope_moca_raw)
MRS_long$t1_age <- as.numeric(MRS_long$t1_age)
# Define the dynamic change variables
predictors_change <- c("hipp_difference", "thickness_difference")
mediators_change <- c("percent_change_glu_prec", "percent_change_glu_acc")
outcome <- "slope_moca_raw"
change_mediation_results <- list()
# 2. The Loop
for (pred in predictors_change) {
for (med in mediators_change) {
# Path A: Rate of Atrophy -> Rate of Glutamate Change
form_m <- reformulate(c(pred, "t1_age", "sexe"), response = med)
med_model <- lm(form_m, data = MRS_long)
# Path B & C': Rate of Atrophy + Rate of Glutamate Change -> Cognitive Slope
form_y <- reformulate(c(med, pred, "t1_age", "sexe"), response = outcome)
out_model <- lm(form_y, data = MRS_long)
# Run Mediation (Bootstrapped)
med_out <- try(mediate(med_model, out_model,
treat = pred,
mediator = med,
boot = TRUE, sims = 1000), silent = TRUE)
if (!inherits(med_out, "try-error")) {
summ <- summary(med_out)
res <- data.frame(
X_Change = pred,
M_Change = med,
ACME_p = summ$d0.p,    # Indirect Effect (The Cascade)
ADE_p = summ$z0.p,     # Direct Effect
Total_p = summ$tau.p,  # Total Effect
Prop_Med = summ$n0     # % of cognitive decline explained by Glu change
)
change_mediation_results[[paste0(pred, "_", med)]] <- res
}
}
}
# 3. Combine and View Results
if(length(change_mediation_results) > 0) {
final_change_med_table <- do.call(rbind, change_mediation_results)
print(final_change_med_table)
} else {
print("No longitudinal mediation models converged.")
}
