library(lmerTest)
# Variables to test
vars_to_test <- c("moca_score_total_30", "glu_precuneus", "glu_acc",
"norm_sum_hippocampus", "norm_cortical_thickness_dickerson")
# Initialize storage
trend_results_age <- data.frame(Variable = character(), Slope_Estimate = numeric(),
P_Value_Raw = numeric(), stringsAsFactors = FALSE)
# Run the loop
for (var in vars_to_test) {
# Formula: Trajectory measured by Age at Visit
# Controlling for sex and education as fixed effects
form <- as.formula(paste(var, "~ age_at_visit + sex + education + (1 | participant_id)"))
model <- try(lmer(form, data = MRS_long), silent = TRUE)
if (!inherits(model, "try-error")) {
coef_table <- summary(model)$coefficients
# Check if 'age_at_visit' exists in the model output
if ("age_at_visit" %in% rownames(coef_table)) {
trend_results_age <- rbind(trend_results_age, data.frame(
Variable = var,
Slope_Estimate = coef_table["age_at_visit", "Estimate"],
P_Value_Raw = coef_table["age_at_visit", "Pr(>|t|)"]
))
}
}
}
# Apply FDR correction
trend_results_age$P_Value_FDR <- p.adjust(trend_results_age$P_Value_Raw, method = "fdr")
# Sort and print
trend_results_age <- trend_results_age[order(trend_results_age$P_Value_FDR), ]
