# Step 1: Identify participants who had "high glu" at their first timepoint
high_glu_ids <- MRS_prediction_long %>%
# Group by participant ID
group_by(pscid) %>%
# Sort chronologically to ensure we look at their first appearance
arrange(years_from_baseline) %>%
# Keep only the first chronological row for each participant
slice(1) %>%
ungroup() %>%
# Define "high" (e.g., greater than 1 standard deviation above the mean)
# Replace 'glutamate_var' with your actual glutamate column name
filter(glutamate_var > mean(glutamate_var, na.rm = TRUE) + sd(glutamate_var, na.rm = TRUE)) %>%
# Extract just their IDs
pull(pscid)
names(MRS_prediction_long)
library(dplyr)
library(ggplot2)
# Step 1: Identify participants who had high precuneus glu (>1 SD) at baseline
high_glu_ids <- MRS_prediction_long %>%
group_by(pscid) %>%
arrange(years_from_baseline) %>%
slice(1) %>%
ungroup() %>%
# Because it is a z-score, > 1 exactly means > 1 Standard Deviation
filter(m_m_precuneus_z > 1) %>%
pull(pscid)
# Step 2: Filter the full dataset to keep ALL timepoints for those specific individuals
high_glu_data <- MRS_prediction_long %>%
filter(pscid %in% high_glu_ids)
# Step 3: Create the spaghetti plot
ggplot(high_glu_data, aes(x = years_from_baseline, y = moca, group = pscid)) +
geom_line(alpha = 0.4, color = "blue") +
geom_point(alpha = 0.6, color = "darkblue") +
theme_minimal() +
labs(
title = "Actual Longitudinal MoCA Trajectories (High Precuneus Glutamate)",
x = "Years from Baseline",
y = "MoCA Score"
)
summary(precuneus_slopes, infer = TRUE)
# 1. Calculate groups at baseline
baseline_groups <- MRS_prediction_long %>%
group_by(pscid) %>%
arrange(years_from_baseline) %>%
slice(1) %>%
ungroup() %>%
mutate(
# Median Split (High vs Low)
glu_median = ifelse(m_m_precuneus_z > median(m_m_precuneus_z, na.rm = TRUE), "High", "Low"),
# Tertiles (1 = Lowest 33%, 3 = Highest 33%)
glu_tertile = ntile(m_m_precuneus_z, 3),
# Quartiles (1 = Lowest 25%, 4 = Highest 25%)
glu_quartile = ntile(m_m_precuneus_z, 4)
) %>%
select(pscid, glu_median, glu_tertile, glu_quartile)
# 2. Join these group labels back to the main dataset
MRS_prediction_long <- MRS_prediction_long %>%
left_join(baseline_groups, by = "pscid") %>%
# Convert them to factors so the lmer model knows they are distinct groups
mutate(
glu_median = as.factor(glu_median),
glu_tertile = as.factor(glu_tertile),
glu_quartile = as.factor(glu_quartile)
)
model_median <- lmer(moca ~ years_from_baseline * glu_median + sexe + diagnostic_nick + education + initiale_age + (1 | pscid),
data = MRS_prediction_long)
# Test the slopes
emtrends(model_median, specs = ~ glu_median, var = "years_from_baseline") %>%
summary(infer = TRUE)
model_tertile <- lmer(moca ~ years_from_baseline * glu_tertile + sexe + diagnostic_nick + education + initiale_age + (1 | pscid),
data = MRS_prediction_long)
# Test the slopes
emtrends(model_tertile, specs = ~ glu_tertile, var = "years_from_baseline") %>%
summary(infer = TRUE)
# Test the slopes
emtrends(model_quartile, specs = ~ glu_quartile, var = "years_from_baseline") %>%
summary(infer = TRUE)
model_quartile <- lmer(moca ~ years_from_baseline * glu_quartile + sexe + diagnostic_nick + education + initiale_age + (1 | pscid),
data = MRS_prediction_long)
# Test the slopes
emtrends(model_quartile, specs = ~ glu_quartile, var = "years_from_baseline") %>%
summary(infer = TRUE)
