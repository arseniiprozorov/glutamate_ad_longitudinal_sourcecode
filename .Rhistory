library(ggplot2)
# Plot: Hippocampal Atrophy predicted by Hippocampal Activation (Quadratic)
ggplot(MRS_long, aes(x = hipp_l_diff_activation, y = hipp_difference, color = diagnostic_nick)) +
geom_point(alpha = 0.7, size = 2.5) +
# Add the quadratic regression line exactly as it is in your lm() model
geom_smooth(method = "lm", formula = y ~ x + I(x^2), se = TRUE, linewidth = 1.2, aes(fill = diagnostic_nick)) +
# Split the graph by clinical group
facet_wrap(~ diagnostic_nick) +
scale_color_manual(values = c("HC" = "#3B5998", "SCD+" = "#E69F00", "MCI" = "#D55E00", "SCD+ and MCI" = "#D55E00")) +
scale_fill_manual(values = c("HC" = "#3B5998", "SCD+" = "#E69F00", "MCI" = "#D55E00", "SCD+ and MCI" = "#D55E00")) +
labs(
title = "Biphasic Relationship: Functional Activation vs. Structural Atrophy",
subtitle = "Quadratic fits split by clinical diagnosis",
x = "Annualized Change in Hippocampal Activation (Function)",
y = "Change in Hippocampal Volume (Structure)",
color = "Diagnosis",
fill = "Diagnosis"
) +
theme_minimal() +
theme(panel.grid.minor = element_blank(), legend.position = "none")
# Plot: Hippocampal Atrophy predicted by Hippocampal Activation (Quadratic)
ggplot(MRS_long, aes(x = hipp_l_diff_activation, y = t2_hipp_e_tiv, color = diagnostic_nick)) +
geom_point(alpha = 0.7, size = 2.5) +
# Add the quadratic regression line exactly as it is in your lm() model
geom_smooth(method = "lm", formula = y ~ x + I(x^2), se = TRUE, linewidth = 1.2, aes(fill = diagnostic_nick)) +
# Split the graph by clinical group
facet_wrap(~ diagnostic_nick) +
scale_color_manual(values = c("HC" = "#3B5998", "SCD+" = "#E69F00", "MCI" = "#D55E00", "SCD+ and MCI" = "#D55E00")) +
scale_fill_manual(values = c("HC" = "#3B5998", "SCD+" = "#E69F00", "MCI" = "#D55E00", "SCD+ and MCI" = "#D55E00")) +
labs(
title = "Biphasic Relationship: Functional Activation vs. Structural Atrophy",
subtitle = "Quadratic fits split by clinical diagnosis",
x = "Annualized Change in Hippocampal Activation (Function)",
y = "Change in Hippocampal Volume (Structure)",
color = "Diagnosis",
fill = "Diagnosis"
) +
theme_minimal() +
theme(panel.grid.minor = element_blank(), legend.position = "none")
# Get the unique diagnostic groups
groups <- unique(na.omit(MRS_long$diagnostic_nick))
# Loop through each group and run the quadratic model
for (group in groups) {
cat("\n========================================================\n")
cat("       RESULTS FOR GROUP:", as.character(group), "\n")
cat("========================================================\n")
# Subset data for just this group
group_data <- subset(MRS_long, diagnostic_nick == group)
# Run the exact quadratic formula used in the ggplot
model <- lm(hipp_difference ~ hipp_l_diff_activation + I(hipp_l_diff_activation^2), data = group_data)
# Print the results
print(summary(model))
}
