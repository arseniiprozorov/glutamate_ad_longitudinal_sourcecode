summary(mixed_model_precuneus_sub)
precuneus_slopes_sub <- emtrends(mixed_model_precuneus_sub, specs = ~ m_m_precuneus_z,
var = "years_from_baseline",
at = list(m_m_precuneus_z = c(-1, 0, 1)))
summary(precuneus_slopes_sub, infer = TRUE)
anova(mixed_model_precuneus_sub)
# Notice we are now using data = MRS_subset
mixed_model_precuneus_sub <- lmer(moca ~ years_from_baseline * m_m_precuneus_z + sexe + diagnostic_nick + education + initiale_age + (1 | pscid),
data = MRS_subset)
summary(mixed_model_precuneus_sub)
precuneus_slopes_sub <- emtrends(mixed_model_precuneus_sub, specs = ~ m_m_precuneus_z,
var = "years_from_baseline",
at = list(m_m_precuneus_z = c(-1, 0, 1)))
summary(precuneus_slopes_sub, infer = TRUE)
anova(mixed_model_precuneus_sub)
mixed_model_acc_sub <- lmer(moca ~ years_from_baseline * m_m_acc_z + sexe + diagnostic_nick + education + initiale_age + (1 | pscid),
data = MRS_subset)
summary(mixed_model_acc_sub)
acc_slopes_sub <- emtrends(mixed_model_acc_sub, specs = ~ m_m_acc_z,
var = "years_from_baseline",
at = list(m_m_acc_z = c(-1, 0, 1)))
summary(acc_slopes_sub, infer = TRUE)
anova(mixed_model_acc_sub)
ggplot(MRS_prediction, aes(x = m_m_precuneus, y = initiale_moca_score_total_30)) +
# We map the color strictly to the points here
geom_point(aes(color = diagnostic_nick), alpha = 0.7, size = 2.5) +
# The overall quadratic line (made black so it stands out against the colored dots)
stat_smooth(method = "lm", formula = y ~ x + I(x^2),
color = "black", fill = "gray80", linewidth = 1.2) +
theme_minimal(base_size = 14) +
# Customizing the colors manually (Optional, but looks great for posters)
scale_color_manual(values = c("MCI" = "#E69F00", "SCD+" = "#56B4E9")) +
labs(
title = "Baseline Precuneus Glutamate vs. MoCA",
subtitle = "Quadratic trajectory across clinical diagnoses",
x = "Precuneus Glutamate (Raw)",
y = "Initial MoCA Score (Max 30)",
color = "Diagnosis" # This renames the legend nicely
) +
coord_cartesian(ylim = c(15, 30))
library(ggplot2)
# 1. Convert the binary 0/1 decliner variable into a clean factor for the legend
MRS_prediction$decliner_factor <- factor(MRS_prediction$decliner_regression,
levels = c(0, 1),
labels = c("Stable", "Declined"))
# 2. Build the plot
ggplot(MRS_prediction, aes(x = m_m_precuneus, y = initiale_moca_score_total_30)) +
# Map color to diagnosis (MCI/SCD+) and shape to longitudinal outcome
geom_point(aes(color = diagnostic_nick, shape = decliner_factor),
alpha = 0.8, size = 3) +
# The overarching quadratic biological curve (kept black to anchor the colored points)
stat_smooth(method = "lm", formula = y ~ x + I(x^2),
color = "black", fill = "gray80", linewidth = 1.2) +
theme_minimal(base_size = 14) +
# Custom poster-ready colors (colorblind-friendly) and shapes (16=circle, 17=triangle)
scale_color_manual(values = c("MCI" = "#E69F00", "SCD+" = "#56B4E9")) +
scale_shape_manual(values = c("Stable" = 16, "Declined" = 17)) +
labs(
title = "Baseline Precuneus Glutamate vs. Initial MoCA",
subtitle = "Quadratic trajectory mapped by Diagnosis and Future Decline",
x = "Precuneus Glutamate (Raw)",
y = "Initial MoCA Score (Max 30)",
color = "Baseline Diagnosis",
shape = "Longitudinal Outcome"
) +
coord_cartesian(ylim = c(15, 30))
