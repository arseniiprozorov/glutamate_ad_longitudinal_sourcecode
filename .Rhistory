# Define the list of predictors
predictors <- c(
"plasma_ptau217_z",
"m_m_precuneus_z",
"m_m_acc_z",
"hipp_mean_z",
"cortical_thickness_adsignature_dickson_z",
"hipp_mean_act_z",
"activation_parietal_sup_l_z"
)
# Generate all unique pairs of predictors
predictor_pairs <- combn(predictors, 2, simplify = FALSE)
# Initialize an empty dataframe to store the results
results_df <- data.frame(
Model_Predictors = character(),
AUC = numeric(),
AIC = numeric(),
stringsAsFactors = FALSE
)
# Loop through each pair
for (pair in predictor_pairs) {
# Create the formula string (e.g., "converter_to_mci ~ plasma_ptau217_z + hipp_mean_z")
formula_str <- paste("converter_to_mci ~", pair[1], "+", pair[2])
# Fit the model (using tryCatch to avoid stopping if a model fails to converge)
tryCatch({
model <- glm(as.formula(formula_str), data = MRS_prediction, family = "binomial")
# Calculate ROC and AUC
# Note: model$y extracts the actual outcome values used in the model (ignoring NAs)
model_roc <- roc(model$y, fitted(model), quiet = TRUE)
model_auc <- as.numeric(auc(model_roc))
model_aic <- AIC(model)
# Append to results dataframe
results_df <- rbind(results_df, data.frame(
Model_Predictors = paste(pair[1], "&", pair[2]),
AUC = round(model_auc, 4),
AIC = round(model_aic, 2)
))
}, error = function(e) {
message(paste("Error fitting model for:", formula_str))
})
}
# Sort the results by the highest AUC (and then lowest AIC as a tie-breaker)
best_paired_models <- results_df[order(-results_df$AUC, results_df$AIC), ]
# View the leaderboard
print("Top Paired Models Predicting Conversion to MCI:")
print(head(best_paired_models, 10)) # Shows the top 10 combinations
