library(psych)
library(corrplot)
library(dplyr)
# 1. Define the variables
cor_vars <- c(
"t1_age", "t2_age", "education",
"t1_glu_prec", "t2_glu_prec", "percent_change_glu_prec",
"t1_glu_acc", "t2_glu_acc", "percent_change_glu_acc",
"t1_cortical_thickness_dickson", "t2_cortical_thickness_dickson", "thickness_difference",
"t1_hipp_e_tiv", "t2_hipp_e_tiv", "hipp_difference",
"slope_moca_raw"
)
# 2. Define the trajectories to loop through
trajectories <- list(
prec_inc = list(var = "traj_glu_prec", level = "Increasing"),
prec_dec = list(var = "traj_glu_prec", level = "Decreasing"),
acc_inc  = list(var = "traj_glu_acc", level = "Increasing"),
acc_dec  = list(var = "traj_glu_acc", level = "Decreasing")
)
# 3. Loop and generate 4 matrices/plots
for (name in names(trajectories)) {
# Subset data
traj_info <- trajectories[[name]]
sub_data <- MRS_long %>% filter(!!sym(traj_info$var) == traj_info$level)
# Calculate Correlation
cor_results <- corr.test(sub_data[, cor_vars], use = "pairwise",
method = "pearson", adjust = "none")
r_matrix <- cor_results$r
p_matrix <- cor_results$p
# Plot
cat("\n--- Plotting for:", name, "---\n")
corrplot(r_matrix, method = "color", type = "upper", order = "hclust",
hclust.method = "ward.D2", p.mat = p_matrix, sig.level = 0.05,
insig = "pch", addCoef.col = "red", number.cex = 0.7,
title = paste("Trajectory:", name), mar = c(0,0,1,0))
}
library(psych)
library(corrplot)
library(dplyr)
# ---------------------------------------------------------
# HELPER FUNCTION: Flatten and sort correlation matrices
# ---------------------------------------------------------
extract_sorted_corrs <- function(cor_res, p_cutoff = 1.0) {
r_mat <- cor_res$r
p_mat <- cor_res$p
# Extract the upper triangle to avoid duplicates and self-correlations (1.0)
upper_tri <- upper.tri(r_mat)
# Create a clean data frame
cor_df <- data.frame(
Variable_1 = rownames(r_mat)[row(r_mat)[upper_tri]],
Variable_2 = colnames(r_mat)[col(r_mat)[upper_tri]],
R_value = r_mat[upper_tri],
P_value = p_mat[upper_tri]
)
# Sort from most significant (smallest p) to least, and apply optional filter
cor_df <- cor_df %>%
arrange(P_value) %>%
filter(P_value <= p_cutoff)
# Round values for cleaner reading
cor_df$R_value <- round(cor_df$R_value, 3)
cor_df$P_value <- round(cor_df$P_value, 4)
return(cor_df)
}
# =========================================================
# 1. WHOLE SAMPLE RESULTS
# =========================================================
cor_vars <- c(
"t1_age", "t2_age", "education",
"t1_glu_prec", "t2_glu_prec", "percent_change_glu_prec",
"t1_glu_acc", "t2_glu_acc", "percent_change_glu_acc",
"t1_cortical_thickness_dickson", "t2_cortical_thickness_dickson", "thickness_difference",
"t1_hipp_e_tiv", "t2_hipp_e_tiv", "hipp_difference",
"slope_moca_raw"
)
cor_results_whole <- corr.test(MRS_long[, cor_vars], use = "pairwise",
method = "pearson",  adjust = "none")
# Get sorted results for the whole sample (Optional: change p_cutoff to 0.05 to only see sig results)
whole_sample_sorted <- extract_sorted_corrs(cor_results_whole, p_cutoff = 1.0)
cat("\n--- TOP CORRELATIONS: WHOLE SAMPLE ---\n")
print(head(whole_sample_sorted, 15)) # Prints the top 15 most significant
# =========================================================
# 2. SUBGROUP TRAJECTORIES (Increasers vs Decreasers)
# =========================================================
trajectories <- list(
prec_inc = list(var = "traj_glu_prec", level = "Increasing"),
prec_dec = list(var = "traj_glu_prec", level = "Decreasing"),
acc_inc  = list(var = "traj_glu_acc", level = "Increasing"),
acc_dec  = list(var = "traj_glu_acc", level = "Decreasing")
)
# Optional: Create a list to save the full sorted tables if you want to export them later
all_subgroup_tables <- list()
# 3. Loop and generate matrices, plots, and sorted console output
for (name in names(trajectories)) {
# Subset data
traj_info <- trajectories[[name]]
sub_data <- MRS_long %>% filter(!!sym(traj_info$var) == traj_info$level)
# Calculate Correlation
cor_results <- corr.test(sub_data[, cor_vars], use = "pairwise",
method = "pearson", adjust = "none")
r_matrix <- cor_results$r
p_matrix <- cor_results$p
# --- NEW: Extract and print sorted results ---
sorted_table <- extract_sorted_corrs(cor_results)
all_subgroup_tables[[name]] <- sorted_table # Save to list
cat("\n======================================================\n")
cat("--- TOP CORRELATIONS FOR:", toupper(name), "---\n")
cat("======================================================\n")
# Print the top 10 most significant hits for this subgroup
print(head(sorted_table, 10))
cat("\n")
# Plot
corrplot(r_matrix, method = "color", type = "upper", order = "hclust",
hclust.method = "ward.D2", p.mat = p_matrix, sig.level = 0.05,
insig = "pch", addCoef.col = "red", number.cex = 0.7,
title = paste("Trajectory:", name), mar = c(0,0,1,0))
}
library(psych)
library(corrplot)
library(dplyr)
# ---------------------------------------------------------
# HELPER FUNCTION: Flatten, sort, and remove intra-correlations
# ---------------------------------------------------------
extract_sorted_corrs <- function(cor_res, p_cutoff = 1.0) {
r_mat <- cor_res$r
p_mat <- cor_res$p
# Extract the upper triangle to avoid duplicates and self-correlations (1.0)
upper_tri <- upper.tri(r_mat)
# Create a clean data frame
cor_df <- data.frame(
Variable_1 = rownames(r_mat)[row(r_mat)[upper_tri]],
Variable_2 = colnames(r_mat)[col(r_mat)[upper_tri]],
R_value = r_mat[upper_tri],
P_value = p_mat[upper_tri]
)
# --- NEW: Define families to exclude same-variable correlations ---
family_map <- c(
"t1_age" = "age", "t2_age" = "age",
"t1_glu_prec" = "prec", "t2_glu_prec" = "prec", "percent_change_glu_prec" = "prec",
"t1_glu_acc" = "acc", "t2_glu_acc" = "acc", "percent_change_glu_acc" = "acc",
"t1_cortical_thickness_dickson" = "dickson", "t2_cortical_thickness_dickson" = "dickson", "thickness_difference" = "dickson",
"t1_hipp_e_tiv" = "hipp", "t2_hipp_e_tiv" = "hipp", "hipp_difference" = "hipp"
)
# Apply filters and sort
cor_df <- cor_df %>%
mutate(
fam1 = family_map[Variable_1],
fam2 = family_map[Variable_2]
) %>%
# Keep row if families are DIFFERENT, or if a variable has no family (e.g., NA for moca/education)
filter(is.na(fam1) | is.na(fam2) | fam1 != fam2) %>%
select(-fam1, -fam2) %>% # Clean up the temporary family columns
arrange(P_value) %>%
filter(P_value <= p_cutoff)
# Round values for cleaner reading
cor_df$R_value <- round(cor_df$R_value, 3)
cor_df$P_value <- round(cor_df$P_value, 4)
return(cor_df)
}
# =========================================================
# 1. WHOLE SAMPLE RESULTS
# =========================================================
cor_vars <- c(
"t1_age", "t2_age", "education",
"t1_glu_prec", "t2_glu_prec", "percent_change_glu_prec",
"t1_glu_acc", "t2_glu_acc", "percent_change_glu_acc",
"t1_cortical_thickness_dickson", "t2_cortical_thickness_dickson", "thickness_difference",
"t1_hipp_e_tiv", "t2_hipp_e_tiv", "hipp_difference",
"slope_moca_raw"
)
cor_results_whole <- corr.test(MRS_long[, cor_vars], use = "pairwise",
method = "pearson",  adjust = "none")
# Get sorted results for the whole sample
whole_sample_sorted <- extract_sorted_corrs(cor_results_whole, p_cutoff = 1.0)
cat("\n--- TOP CORRELATIONS: WHOLE SAMPLE (Intra-domain excluded) ---\n")
print(head(whole_sample_sorted, 15))
# =========================================================
# 2. SUBGROUP TRAJECTORIES (Increasers vs Decreasers)
# =========================================================
trajectories <- list(
prec_inc = list(var = "traj_glu_prec", level = "Increasing"),
prec_dec = list(var = "traj_glu_prec", level = "Decreasing"),
acc_inc  = list(var = "traj_glu_acc", level = "Increasing"),
acc_dec  = list(var = "traj_glu_acc", level = "Decreasing")
)
all_subgroup_tables <- list()
# 3. Loop and generate matrices, plots, and sorted console output
for (name in names(trajectories)) {
# Subset data
traj_info <- trajectories[[name]]
sub_data <- MRS_long %>% filter(!!sym(traj_info$var) == traj_info$level)
# Calculate Correlation
cor_results <- corr.test(sub_data[, cor_vars], use = "pairwise",
method = "pearson", adjust = "none")
r_matrix <- cor_results$r
p_matrix <- cor_results$p
# Extract and print sorted results
sorted_table <- extract_sorted_corrs(cor_results)
all_subgroup_tables[[name]] <- sorted_table
cat("\n======================================================\n")
cat("--- TOP CORRELATIONS FOR:", toupper(name), "---\n")
cat("======================================================\n")
print(head(sorted_table, 10))
cat("\n")
# Plot
corrplot(r_matrix, method = "color", type = "upper", order = "hclust",
hclust.method = "ward.D2", p.mat = p_matrix, sig.level = 0.05,
insig = "pch", addCoef.col = "red", number.cex = 0.7,
title = paste("Trajectory:", name), mar = c(0,0,1,0))
}
