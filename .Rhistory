# 2. The Loop
for (pred in predictors_change) {
# Center the Predictor (Rate of Atrophy)
c_x <- as.numeric(scale(MRS_long[[pred]], center = TRUE, scale = FALSE))
for (mod in moderators_change) {
# Center the Moderator (Rate of Glutamate Change)
c_m <- as.numeric(scale(MRS_long[[mod]], center = TRUE, scale = FALSE))
# Formula: Slope ~ Atrophy_Rate * Glu_Change_Rate + Controls
# Using backticks to ensure variables with special characters are handled
form <- as.formula(paste0("slope_moca_raw ~ c_x * c_m + t1_age + sexe"))
fit <- try(lm(form, data = MRS_long), silent = TRUE)
if (!inherits(fit, "try-error")) {
summ <- summary(fit)$coefficients
interaction_term <- "c_x:c_m"
if (interaction_term %in% rownames(summ)) {
p_val <- summ[interaction_term, "Pr(>|t|)"]
# Capture only significant interactions
if (!is.na(p_val) && p_val < 0.05) {
res <- as.data.frame(t(summ[interaction_term, ]))
res$X_Atrophy_Rate <- pred
res$M_Glu_Change <- mod
res$Interaction_p <- p_val
change_mod_results[[paste0(pred, "_", mod)]] <- res
}
}
}
}
}
# 3. Combine and View
if (length(change_mod_results) > 0) {
final_change_mod_table <- do.call(rbind, change_mod_results)
print(final_change_mod_table[, c("X_Atrophy_Rate", "M_Glu_Change", "Estimate", "Interaction_p")])
} else {
print("No significant longitudinal moderation effects found.")
}
# 1. Define your variables
baseline_glu <- "t1_glu_prec"
change_structure <- "thickness_difference" # Rate of Change in B
baseline_structure <- "t1_cortical_thickness_dickson" # Baseline B
change_glu <- "percent_change_glu_prec" # Rate of Change in A
# 2. Run the three "Villain" models
# Model 1: The Sequential Path (Baseline A -> Rate of Change B)
mod1 <- lm(as.formula(paste(change_structure, "~", baseline_glu, "+ t1_age + sexe")), data = MRS_long)
# Model 2: The Reverse Path (Rate of Change A -> Baseline B)
mod2 <- lm(as.formula(paste(baseline_structure, "~", change_glu, "+ t1_age + sexe")), data = MRS_long)
# Model 3: The Cross-sectional Path (Baseline A -> Baseline B)
mod3 <- lm(as.formula(paste(baseline_structure, "~", baseline_glu, "+ t1_age + sexe")), data = MRS_long)
# 3. Extract and compare Partial Correlations (r)
