scale_color_manual(values = c("HC" = "#3B5998",
"SCD+" = "#E69F00",
"MCI" = "#D55E00",
"SCD+ and MCI" = "#D55E00")) +
labs(
title = "",
subtitle = "",
x = "Baseline Glutamate Concentration (mM)",
y = "Annualized Change in Left Hippocampal Activation",
color = "Diagnosis"
) +
theme_minimal() +
theme(panel.grid.minor = element_blank())
