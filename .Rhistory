library(tidyr)
library(dplyr)
library(lme4)
library(lmerTest) # Gives you p-values for LMMs
# Pivot your activation and glutamate data
MRS_long_lmm <- MRS_long %>%
pivot_longer(
cols = c(hippocampus_avg_activation_t1, hippocampus_avg_activation_t2),
names_to = "Time",
values_to = "Hipp_Activation"
) %>%
mutate(Time = ifelse(grepl("t1", Time), 0, 1)) # 0 for T1, 1 for T2
# Model: Does Glu at T1 predict the change in Activation over time?
# (1 | pscid) accounts for the fact that observations are nested within people
model_lmm <- lmer(Hipp_Activation ~ Time * t1_glu_acc + (1 | pscid),
data = MRS_long_lmm)
summary(model_lmm)
# Multiple Regression predicting PRECUNEUS Glutamate
# Note: I used the averaged left/right variables to avoid multicollinearity
mult_reg_prec <- lm(t1_glu_prec ~ acc_t1_avg_activation +
precuneus_t1_avg_act +
parietal_sup_l_average_t1 +
parietal_sup_r_average_t1 +
hippocampus_avg_activation_t1,
data = MRS_long)
summary(mult_reg_prec)
# Multiple Regression predicting ACC Glutamate
mult_reg_acc <- lm(t1_glu_acc ~ acc_t1_avg_activation +
precuneus_t1_avg_act +
parietal_sup_l_average_t1 +
parietal_sup_r_average_t1 +
hippocampus_avg_activation_t1,
data = MRS_long)
summary(mult_reg_acc)
names(MRS_long)
# ---------------------------------------------------------
# Modèle 1 : Structure ~ Glu
# (Baseline Precuneus Glu predicting annual % hippocampal atrophy)
# ---------------------------------------------------------
mod1_struct_glu <- lm(perc_change_hipp ~ t1_glu_prec, data = MRS_long)
# ---------------------------------------------------------
# Modèle 1 : Structure ~ Glu
# (Baseline Precuneus Glu predicting % change in hippocampus)
# ---------------------------------------------------------
mod1_struct_glu <- lm(hipp_difference ~ t1_glu_prec, data = MRS_long)
summary(mod1_struct_glu)
# Modèle 1 Contrôle : Le volume de l'hippocampe à T1 prédit-il le % changement de Glu ?
mod1_control <- lm(percent_change_glu_prec ~ t1_hipp_e_tiv, data = MRS_long)
summary(mod1_control)
# ---------------------------------------------------------
# Modèle 2 : Activation ~ Glu
# (Baseline Precuneus Glu predicting % change in parietal activation)
# ---------------------------------------------------------
mod2_act_glu <- lm(parietal_sup_l_diff ~ t1_glu_prec, data = MRS_long)
summary(mod2_act_glu)
# Modèle 2 Contrôle : L'activation pariétale à T1 prédit-elle le % changement de Glu ?
mod2_control <- lm(percent_change_glu_prec ~ parietal_sup_l_average_t1, data = MRS_long)
summary(mod2_control)
# ---------------------------------------------------------
# Modèle 3 : Structure ~ Activation (Contrôle)
# (Le % changement d'activation de l'hippocampe est-il corrélé à son atrophie ?)
# ---------------------------------------------------------
mod3_struct_act <- lm(hipp_diff_activation ~ hipp_difference, data = MRS_long)
summary(mod3_struct_act)
# ---------------------------------------------------------
# Modèle 4 : Cognition ~ Structure
# (Le % changement de l'hippocampe prédit-il la pente du MoCA ?)
# ---------------------------------------------------------
mod4_struct_moca <- lm(slope_moca_raw ~ hipp_difference, data = MRS_long)
summary(mod4_struct_moca)
library(dplyr)
library(lme4)
library(lmerTest) # Requis pour obtenir les p-values avec lmer
# 1. Créer la "moitié T1" des données (Temps = 0)
data_t1 <- MRS_long %>%
select(pscid,
struct_hipp = t1_hipp_e_tiv,
glu_prec = t1_glu_prec,
act_par = parietal_sup_l_average_t1,
act_hipp = hippocampus_avg_activation_t1) %>%
mutate(Time = 0)
library(dplyr)
library(lme4)
library(lmerTest)
# 1. Créer la "moitié T1" des données (Temps = 0)
data_t1 <- MRS_long %>%
dplyr::select(pscid,
struct_hipp = t1_hipp_e_tiv,
glu_prec = t1_glu_prec,
act_par = parietal_sup_l_average_t1,
act_hipp = hippocampus_avg_activation_t1) %>%
mutate(Time = 0)
# 2. Créer la "moitié T2" des données (Temps = délai en années)
data_t2 <- MRS_long %>%
dplyr::select(pscid,
struct_hipp = t2_hipp_e_tiv,
glu_prec = t2_glu_prec,
act_par = parietal_sup_l_average_t2,
act_hipp = hippocampus_avg_activation_t2) %>%
left_join(MRS_long %>% dplyr::select(pscid, age_difference), by = "pscid") %>%
mutate(Time = age_difference) %>%
dplyr::select(-age_difference)
# 3. Empiler T1 et T2, puis rajouter les prédicteurs baseline (T1) pour tout le monde
MRS_lmm <- bind_rows(data_t1, data_t2) %>%
left_join(MRS_long %>% dplyr::select(pscid, t1_glu_prec, t1_hipp_e_tiv, parietal_sup_l_average_t1, hipp_difference), by = "pscid")
# ---------------------------------------------------------
# Modèle 1 : Structure ~ Glu
# (Interaction : La pente de l'hippocampe est-elle prédite par le Glu baseline ?)
# ---------------------------------------------------------
mod1_struct_glu_lmm <- lmer(struct_hipp ~ Time * t1_glu_prec + (1 | pscid), data = MRS_lmm)
summary(mod1_struct_glu_lmm)
# Modèle 1 Contrôle : La pente du Glu est-elle prédite par le volume baseline ?
mod1_control_lmm <- lmer(glu_prec ~ Time * t1_hipp_e_tiv + (1 | pscid), data = MRS_lmm)
summary(mod1_control_lmm)
# ---------------------------------------------------------
# Modèle 2 : Activation ~ Glu
# (Interaction : La pente de l'activation pariétale est-elle prédite par le Glu baseline ?)
# ---------------------------------------------------------
mod2_act_glu_lmm <- lmer(act_par ~ Time * t1_glu_prec + (1 | pscid), data = MRS_lmm)
summary(mod2_act_glu_lmm)
# Modèle 2 Contrôle : La pente du Glu est-elle prédite par l'activation baseline ?
mod2_control_lmm <- lmer(glu_prec ~ Time * parietal_sup_l_average_t1 + (1 | pscid), data = MRS_lmm)
summary(mod2_control_lmm)
