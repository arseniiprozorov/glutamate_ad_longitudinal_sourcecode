library(dplyr)
library(corrplot)
# 1. Select T2 structure and T2/Diff activation variables
vars_to_correlate <- MRS_long %>%
select(
# T2 Structure (The Predictors)
t2_cortical_thickness_dickson,
t2_hipp_e_tiv,
# Structural Differences (Change in hardware)
thickness_difference,
hipp_difference,
# T2 Activation (Functional State at T2)
hippocampus_l_average_t2,
hippocampus_r_average_t2,
hippocampus_avg_activation_t2,
parietal_sup_l_average_t2,
parietal_sup_r_average_t2,
precuneus_t2_avg_act,
acc_t2_avg_activation,
# Activation Differences (Functional Plasticity)
hipp_diff_activation,
parietal_sup_l_diff,
precuneus_diff,
acc_diff
)
# 2. Compute correlation matrix and p-values
cor_matrix <- cor(vars_to_correlate, use = "pairwise.complete.obs", method = "pearson")
p_matrix <- cor.mtest(vars_to_correlate, conf.level = 0.95)$p
# 3. Visualize the "Structure-Function" Matrix
corrplot(cor_matrix,
method = "color",
order = "hclust",         # Clusters structure with the function it drives
hclust.method = "ward.D",
addrect = 3,              # Likely clusters into Structure, T2 Act, and Diffs
p.mat = p_matrix,
sig.level = 0.05,
insig = "pch",            # Crosses out non-significant structural-functional links
pch.col = "gray40",
tl.col = "black",
tl.cex = 0.7,
tl.srt = 45,
diag = FALSE)
# Install the package if you don't have it
# install.packages("lavaan")
library(lavaan)
# 1. Define the mediation model syntax
mediation_model <- '
# [a path] Effect of Predictor on Mediator
comp_struct_t2 ~ a * comp_glu_t1
# [b path] Effect of Mediator on Outcome
# [c prime path] Direct effect of Predictor on Outcome
z_moca_slope ~ b * comp_struct_t2 + c * comp_glu_t1
# Calculate the Indirect Effect (a * b)
indirect := a * b
# Calculate the Total Effect (c + a*b)
total := c + (a * b)
'
# 2. Fit the model to your data
# Bootstrapping (e.g., 1000 or 5000 draws) is highly recommended for mediation
# to get robust confidence intervals for the indirect effect.
set.seed(123) # Set seed for reproducible bootstrapping
fit <- sem(model = mediation_model,
data = MRS_long,
se = "bootstrap",
bootstrap = 1000)
# 3. View the results
summary(fit,
fit.measures = TRUE,
standardized = TRUE,
rsquare = TRUE,
ci = TRUE) # ci = TRUE outputs the confidence intervals
# M ~ X
model_m_comb <- lm(comp_glu_t1 ~ comp_struct_t1, data = mediation_combined)
library(mediation)
## Reproducing Article 1 # Mean Structure -> Mean Glu -> Mean Activation
# M ~ X
