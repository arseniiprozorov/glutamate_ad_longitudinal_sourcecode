library(ggplot2)
library(dplyr)
library(tidyr)
# 1. Prepare data (Extracting the two different relationships and stacking them)
df_acc_hipp <- MRS_long %>%
select(pscid, diagnostic_nick, x_val = t1_glu_acc, y_val = t2_hipp_e_tiv) %>%
mutate(Relationship = "ACC Glutamate vs. T2 Hippocampus")
df_prec_thick <- MRS_long %>%
select(pscid, diagnostic_nick, x_val = t1_glu_prec, y_val = t2_cortical_thickness_dickson) %>%
mutate(Relationship = "Precuneus Glutamate vs. T2 Cortical Thickness")
plot_data_struct <- bind_rows(df_acc_hipp, df_prec_thick) %>%
# Ensure the diagnostic groups are ordered correctly
mutate(diagnostic_nick = factor(diagnostic_nick, levels = c("HC", "SCD+", "MCI")))
# 2. Create group-wise regression plot
ggplot(plot_data_struct, aes(x = x_val, y = y_val, color = diagnostic_nick, fill = diagnostic_nick)) +
geom_point(alpha = 0.6, size = 2.5) +
# Add separate regression lines for each diagnostic group
geom_smooth(method = "lm", alpha = 0.2, linewidth = 1.2) +
# Facet by relationship. 'scales = "free"' is crucial here because
# volume and thickness are measured on completely different numerical scales!
facet_wrap(~ Relationship, scales = "free") +
# Styling (using the exact colors from your example)
scale_color_manual(values = c("HC" = "#3B5998", "SCD+" = "#E69F00", "MCI" = "#D55E00")) +
scale_fill_manual(values = c("HC" = "#3B5998", "SCD+" = "#E69F00", "MCI" = "#D55E00")) +
labs(
title = "Group-Wise Associations: Baseline Glutamate vs. Follow-up Brain Structure",
subtitle = "Comparing ACC-Hippocampal and Precuneus-Dickerson Thickness pathways",
x = "Baseline Glutamate Concentration (mM)",
y = "Structural Metric (eTIV Volume / Cortical Thickness)",
color = "Diagnosis",
fill = "Diagnosis"
) +
theme_minimal() +
theme(
panel.grid.minor = element_blank(),
strip.text = element_text(size = 12, face = "bold"), # Makes the facet titles pop
strip.background = element_rect(fill = "gray95", color = NA) # Adds a light background to titles
)
