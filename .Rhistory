library(ggplot2)
# Calculate the vertex (tipping point) for the plot annotation
# Formula: -b / 2a
b_linear <- 3.2528
a_quadratic <- -18.6600
tipping_point <- -b_linear / (2 * a_quadratic)
ggplot(MRS_long, aes(x = t2_thick_c, y = t1_glu_prec)) +
# Add raw data points, colored by diagnosis if available
geom_point(aes(color = diagnostic_nick), alpha = 0.7, size = 3) +
# Add the quadratic fit line with confidence interval
stat_smooth(method = "lm", formula = y ~ x + I(x^2),
color = "darkred", fill = "indianred", alpha = 0.2) +
# Add a vertical line at the "Tipping Point"
geom_vline(xintercept = tipping_point, linetype = "dashed", color = "black", alpha = 0.5) +
# Annotate the peak
annotate("text", x = tipping_point + 0.05, y = 18,
label = paste("Tipping Point:", round(tipping_point, 3), "mm"),
hjust = 0, fontface = "italic") +
# Aesthetics and Labels
theme_minimal(base_size = 14) +
labs(
title = "The Glutamatergic Tipping Point",
subtitle = "Precuneus Glutamate (T1) vs. Cortical Thickness (T2)",
x = "Centered Cortical Thickness at Follow-up (mm)",
y = "Baseline Precuneus Glutamate (mM)",
color = "Diagnosis",
caption = "Negative quadratic term indicates a biphasic relationship (p = .037)"
) +
theme(
legend.position = "bottom",
plot.title = element_text(face = "bold", size = 18),
panel.grid.minor = element_blank()
)
