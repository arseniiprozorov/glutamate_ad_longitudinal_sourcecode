summary(coxph(Surv(followup_years, decliner_regression) ~ m_m_acc_z + initiale_age, data = cox_data))
# 1. Create the isolated dataset using a completely unique column name
cox_data <- MRS_prediction_long %>%
group_by(pscid) %>%
summarize(followup_years = max(years_from_baseline, na.rm = TRUE)) %>%
left_join(MRS_prediction, by = "pscid")
summary(coxph(Surv(followup_years, decliner_regression) ~ m_m_acc_z + initiale_age, data = cox_data))
library(survival)
summary(coxph(Surv(followup_years, decliner_regression) ~ m_m_acc_z + initiale_age, data = cox_data))
summary(coxph(Surv(followup_years, decliner_regression) ~ m_m_precuneus_z + initiale_age, data = cox_data))
# 1. Overall Time to 50% Decline for the whole cohort
survfit(Surv(followup_years, decliner_regression) ~ 1, data = cox_data)
# 2. Time to 50% Decline split by your ACC Glutamate groups
survfit(Surv(followup_years, decliner_regression) ~ acc_strata, data = cox_data)
# 1. Create the isolated dataset using a completely unique column name
cox_data <- MRS_prediction_long %>%
group_by(pscid) %>%
summarize(followup_years = max(years_from_baseline, na.rm = TRUE)) %>%
left_join(MRS_prediction, by = "pscid")
# 1. Overall Time to 50% Decline for the whole cohort
survfit(Surv(followup_years, decliner_regression) ~ 1, data = cox_data)
# 2. Time to 50% Decline split by your ACC Glutamate groups
survfit(Surv(followup_years, decliner_regression) ~ acc_strata, data = cox_data)
library(survival)
library(dplyr)
# 1. Add the Tertile strata directly into your cox_data
cox_data <- cox_data %>%
mutate(
# Create 3 groups for ACC (1 = Low, 3 = High)
acc_strata = ntile(m_m_acc_z, 3),
# Create 3 groups for Precuneus just in case you need it too
precuneus_strata = ntile(m_m_precuneus_z, 3)
)
# 2. Now run the survival curve for ACC
fit_acc <- survfit(Surv(followup_years, decliner_regression) ~ acc_strata, data = cox_data)
print(fit_acc)
# (Optional) Plot it to see the visual separation of the groups
plot(fit_acc, col = c("red", "blue", "green"),
xlab = "Years", ylab = "Survival Probability (No Decline)",
main = "Time to Decline by ACC Glutamate Tertile")
legend("bottomleft", legend = c("Low Tertile", "Medium", "High"), fill = c("red", "blue", "green"))
# 1. Run your continuous Cox model (which you already know works beautifully)
cox_model_acc <- coxph(Surv(followup_years, decliner_regression) ~ m_m_acc_z + initiale_age, data = cox_data)
# 2. Create a mini-dataset of three hypothetical patients
# We hold age constant at the sample average so we are ONLY looking at the effect of Glutamate
mean_age <- mean(cox_data$initiale_age, na.rm = TRUE)
hypothetical_patients <- data.frame(
m_m_acc_z = c(-1, 0, 1),
initiale_age = c(mean_age, mean_age, mean_age)
)
# 3. Ask the Cox model to generate predicted survival curves for these 3 specific profiles
predicted_survival_acc <- survfit(cox_model_acc, newdata = hypothetical_patients)
# 4. Plot the predicted curves!
plot(predicted_survival_acc,
col = c("red", "blue", "green"),
lwd = 2, # Makes the lines a bit thicker and nicer
xlab = "Years from Baseline",
ylab = "Survival Probability (Proportion not declining)",
main = "Predicted Time to Decline by ACC Glutamate (Standard Deviations)")
# Add a legend so you know which line is which
legend("bottomleft",
legend = c("-1 SD (Low Glu)", "0 SD (Average Glu)", "+1 SD (High Glu)"),
col = c("red", "blue", "green"),
lwd = 2)
