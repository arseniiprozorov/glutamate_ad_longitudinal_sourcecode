data = MRS_long
)
print(summary(cox_tau_alone))
# =========================================================================
# Model 2: The Winning Multimodal Combination (Tau + Glu ACC + Parietal Act)
# =========================================================================
cox_multimodal <- coxph(
Surv(age_change_moca, decliners_numeric) ~ plasma_ptau217 + t1_glu_acc + parietal_sup_l_average_t1 + sexe + education,
data = MRS_long
)
print(summary(cox_multimodal))
# =========================================================================
# 3. Visualization: Kaplan-Meier Curve for Tau (Using a Median Split)
# =========================================================================
# To plot a continuous variable like Tau in a Kaplan-Meier plot,
# we split the participants into "High Tau" vs "Low Tau" groups.
MRS_long$tau_group <- ifelse(
MRS_long$plasma_ptau217 >= median(MRS_long$plasma_ptau217, na.rm = TRUE),
"High p-tau217",
"Low p-tau217"
)
# Fit the Kaplan-Meier survival curve
km_fit <- survfit(Surv(age_change_moca, decliners_numeric) ~ tau_group, data = MRS_long)
# Plot the curves cleanly
ggsurvplot(
km_fit,
data = MRS_long,
pval = TRUE,             # Automatically computes and displays the Log-Rank p-value
conf.int = TRUE,         # Adds confidence intervals
risk.table = TRUE,       # Shows the number of subjects at risk at each age bracket
legend.labs = c("High p-tau217", "Low p-tau217"),
palette = c("#E41A1C", "#377EB8"),
xlab = "Age at MoCA Assessment",
ylab = "Probability of Remaining Cognitively Stable",
title = "Cognitive Decline-Free Survival by Baseline Tau Levels"
)
Clear_all = T
if (Clear_all)
{
closeAllConnections()
rm(list=ls())
graphics.off()
cat("\f")
}
