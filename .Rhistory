# Mean-center the specific glutamate variable
centered_glu <- scale(MRS_long[[glu]], center = TRUE, scale = FALSE)
for (var in test_vars) {
# Dynamically create the formula: var ~ glu + glu^2 + age + sexe
# Using I(centered_glu^2) for the quadratic term
form <- as.formula(paste(var, "~ centered_glu + I(centered_glu^2) + t1_age + sexe"))
# Fit the model
fit <- lm(form, data = MRS_long)
# Store the summary coefficients in a tidy-ish way
res <- as.data.frame(summary(fit)$coefficients)
res$predictor <- glu
res$outcome <- var
res$term <- rownames(res)
results_list[[paste(glu, var, sep = "_")]] <- res
}
}
# 3. Combine results into one table for quick inspection
all_quad_results <- do.call(rbind, results_list)
# 4. Filter to see ONLY the quadratic terms to see where the "curve" is significant
significant_curves <- subset(all_quad_results, grepl("I\\(", term) & `Pr(>|t|)` < 0.05)
print(significant_curves)
