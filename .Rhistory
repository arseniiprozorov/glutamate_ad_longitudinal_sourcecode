library(dplyr)
library(broom)
library(purrr)
# 1. Define your target variable
target <- "decliners"
# 2. Define predictors
# We explicitly remove the ID, the target itself, and the MOCA slope to prevent data leakage.
predictors <- setdiff(names(MRS_long), c("participant_id", "decliners", "slope_moca_raw"))
# 3. Create a custom function to fit a model and extract its AIC
fit_and_score <- function(vars, data) {
# Build the formula (e.g., "decliners ~ glu_precuneus_t_0 + hippocampus_avg_act_t_0")
formula_str <- paste(target, "~", paste(vars, collapse = " + "))
# Run the logistic regression
# Using tryCatch to prevent the loop from crashing if a specific model fails to converge
model <- tryCatch({
glm(as.formula(formula_str), data = data, family = binomial(link = "logit"))
}, error = function(e) return(NULL))
if (is.null(model)) return(NULL)
# Extract metrics using broom
metrics <- glance(model)
# Return a clean summary row
tibble(
model_formula = formula_str,
num_variables = length(vars),
AIC = metrics$AIC,
BIC = metrics$BIC,
deviance = metrics$deviance
)
}
# 4. Generate all possible mathematical combinations
cat("Generating combinations...\n")
combos_1 <- combn(predictors, 1, simplify = FALSE)
combos_2 <- combn(predictors, 2, simplify = FALSE)
combos_3 <- combn(predictors, 3, simplify = FALSE)
# Combine them all into one giant list (~1,700 combinations)
all_combos <- c(combos_1, combos_2, combos_3)
# 5. Run all models! (This might take 5-10 seconds depending on your machine)
cat("Running logistic regressions...\n")
model_results <- map_dfr(all_combos, ~fit_and_score(.x, MRS_long))
# 6. Rank the models from BEST (Lowest AIC) to WORST
ranked_models <- model_results %>%
arrange(AIC)
# View the top 15 best predictive models
print("Top 15 Best Models:")
head(ranked_models, 15)
library(dplyr)
library(broom)
library(purrr)
library(pROC) # For AUC and ROC curve calculations
# 1. Define your target and predictors
target <- "decliners"
predictors <- setdiff(names(MRS_long), c("participant_id", "decliners", "slope_moca_raw"))
# 2. Upgraded custom function to fit a model AND calculate classification metrics
fit_and_score_metrics <- function(vars, data) {
formula_str <- paste(target, "~", paste(vars, collapse = " + "))
# Ensure we only use rows with complete data for the variables in THIS specific model
# This prevents lengths from mismatching when calculating Sensitivity/Specificity
model_data <- data %>% select(all_of(c(target, vars))) %>% drop_na()
# Run the logistic regression
model <- tryCatch({
glm(as.formula(formula_str), data = model_data, family = binomial(link = "logit"))
}, warning = function(w) {
# We suppress the perfect separation warnings here so your console doesn't flood,
# but the model still fits.
suppressWarnings(glm(as.formula(formula_str), data = model_data, family = binomial(link = "logit")))
}, error = function(e) return(NULL))
if (is.null(model)) return(NULL)
metrics <- glance(model)
# 3. Calculate Predictions
# Extract actual outcomes and predict probabilities using the model
actual_y <- model_data[[target]]
pred_probs <- predict(model, type = "response")
# Calculate ROC and AUC
roc_curve <- tryCatch(roc(actual_y, pred_probs, quiet = TRUE), error = function(e) NULL)
if (!is.null(roc_curve)) {
auc_value <- as.numeric(auc(roc_curve))
# Calculate Sensitivity & Specificity using a standard 0.5 probability threshold
pred_class <- ifelse(pred_probs > 0.5, 1, 0)
TP <- sum(pred_class == 1 & actual_y == 1)
TN <- sum(pred_class == 0 & actual_y == 0)
FP <- sum(pred_class == 1 & actual_y == 0)
FN <- sum(pred_class == 0 & actual_y == 1)
# Avoid division by zero if a class is entirely missing
sensitivity <- ifelse((TP + FN) > 0, TP / (TP + FN), NA)
specificity <- ifelse((TN + FP) > 0, TN / (TN + FP), NA)
} else {
auc_value <- NA
sensitivity <- NA
specificity <- NA
}
# Return the full profile for this model
tibble(
model_formula = formula_str,
num_variables = length(vars),
AIC = metrics$AIC,
AUC = auc_value,
Sensitivity = sensitivity,
Specificity = specificity,
deviance = metrics$deviance
)
}
# 4. Generate combinations and run models
cat("Generating combinations...\n")
combos_1 <- combn(predictors, 1, simplify = FALSE)
combos_2 <- combn(predictors, 2, simplify = FALSE)
combos_3 <- combn(predictors, 3, simplify = FALSE)
all_combos <- c(combos_1, combos_2, combos_3)
cat("Running logistic regressions with AUC/Sens/Spec extraction...\n")
model_results_full <- map_dfr(all_combos, ~fit_and_score_metrics(.x, MRS_long))
# 5. Rank by best AIC, but now we can see all the classification metrics
ranked_models_full <- model_results_full %>%
arrange(AIC)
# View the top 15 models
print("Top 15 Models with Full Metrics:")
head(ranked_models_full, 15)
library(dplyr)
library(broom)
library(purrr)
library(pROC)
# 1. Define your target
target <- "decliners"
# 2. Define pure baseline/predictive variables
# Remove ID, target, slope, AND explicitly filter out anything containing "_t_post"
predictors <- setdiff(names(MRS_long), c("participant_id", "decliners", "slope_moca_raw"))
predictors <- predictors[!grepl("_t_post", predictors)]
# 3. Upgraded function: Now tracks 'n' after handling missing data
fit_and_score_metrics <- function(vars, data) {
formula_str <- paste(target, "~", paste(vars, collapse = " + "))
# Ensure we only use rows with complete data for THIS specific model
model_data <- data %>% select(all_of(c(target, vars))) %>% drop_na()
# Calculate exact sample size for this model
n_obs <- nrow(model_data)
# If a combination of variables leaves too few participants, skip it
if (n_obs < 10) return(NULL)
# Fit the model (suppressing the perfect separation warning to keep console clean)
model <- tryCatch({
suppressWarnings(glm(as.formula(formula_str), data = model_data, family = binomial(link = "logit")))
}, error = function(e) return(NULL))
if (is.null(model)) return(NULL)
metrics <- glance(model)
# Extract actuals and predictions
actual_y <- model_data[[target]]
pred_probs <- predict(model, type = "response")
# Calculate ROC and AUC
roc_curve <- tryCatch(roc(actual_y, pred_probs, quiet = TRUE), error = function(e) NULL)
if (!is.null(roc_curve)) {
auc_value <- as.numeric(auc(roc_curve))
# Calculate Sensitivity & Specificity using a standard 0.5 threshold
pred_class <- ifelse(pred_probs > 0.5, 1, 0)
TP <- sum(pred_class == 1 & actual_y == 1)
TN <- sum(pred_class == 0 & actual_y == 0)
FP <- sum(pred_class == 1 & actual_y == 0)
FN <- sum(pred_class == 0 & actual_y == 1)
# Avoid division by zero
sensitivity <- ifelse((TP + FN) > 0, TP / (TP + FN), NA)
specificity <- ifelse((TN + FP) > 0, TN / (TN + FP), NA)
} else {
auc_value <- NA
sensitivity <- NA
specificity <- NA
}
# Return the full profile
tibble(
model_formula = formula_str,
num_variables = length(vars),
n = n_obs,
AIC = metrics$AIC,
AUC = auc_value,
Sensitivity = sensitivity,
Specificity = specificity,
deviance = metrics$deviance
)
}
# 4. Generate pure predictive combinations
cat("Generating predictive baseline combinations...\n")
combos_1 <- combn(predictors, 1, simplify = FALSE)
combos_2 <- combn(predictors, 2, simplify = FALSE)
combos_3 <- combn(predictors, 3, simplify = FALSE)
all_combos <- c(combos_1, combos_2, combos_3)
# 5. Run all models
cat("Running logistic regressions (excluding post data)...\n")
model_results_baseline <- map_dfr(all_combos, ~fit_and_score_metrics(.x, MRS_long))
# 6. Rank by best AIC
ranked_models_baseline <- model_results_baseline %>%
arrange(AIC)
# View the top 15 true predictive models
print("Top 15 Baseline Predictive Models:")
head(ranked_models_baseline, 15)
names(MRS_long)
library(dplyr)
library(tidyr)
library(pROC)
# 1. Filter and prepare the variables
all_vars <- names(MRS_long)
# Isolate predictors: Filter OUT 'post' variables, 'participant_id', 'slope_moca_raw', and the target 'decliners'
target_var <- "decliners"
predictors <- all_vars[!grepl("_post|participant_id|slope_moca_raw|decliners", all_vars)]
# 2. Define a helper function to run the model and extract metrics
evaluate_model <- function(vars, data) {
# Build the formula dynamically
formula_str <- paste(target_var, "~", paste(vars, collapse = " + "))
# Filter to complete cases for the specific variables being tested
# This is crucial so n reflects the actual number of rows used in the model
df_clean <- data %>%
select(all_of(c(target_var, vars))) %>%
drop_na()
n_size <- nrow(df_clean)
# Skip if sample size is 0 or if there's only 1 class of outcome left (can't run logistic regression)
if(n_size == 0 || length(unique(df_clean[[target_var]])) < 2) {
return(NULL)
}
# Fit Logistic Regression
model <- glm(as.formula(formula_str), data = df_clean, family = binomial)
# Predict probabilities
pred_probs <- predict(model, type = "response")
# Calculate ROC and AUC
roc_obj <- roc(df_clean[[target_var]], pred_probs, quiet = TRUE)
auc_val <- as.numeric(auc(roc_obj))
# Get Best Sensitivity and Specificity based on Youden's J statistic
coords_best <- coords(roc_obj, "best", ret = c("specificity", "sensitivity"),
best.method = "youden", transpose = FALSE)
# If multiple thresholds tie for "best", take the first one
spec <- coords_best$specificity[1]
sens <- coords_best$sensitivity[1]
# Return as a structured row
return(data.frame(
Model = paste(vars, collapse = " + "),
N = n_size,
AUC = round(auc_val, 4),
Sensitivity = round(sens, 4),
Specificity = round(spec, 4)
))
}
# 3. Test Single Variables
cat("Evaluating single variables...\n")
results_1var <- bind_rows(lapply(predictors, function(v) evaluate_model(v, MRS_long))) %>%
arrange(desc(AUC))
# 4. Test 2-Variable Combinations
cat("Evaluating 2-variable combinations...\n")
combos_2 <- combn(predictors, 2, simplify = FALSE)
results_2var <- bind_rows(lapply(combos_2, function(v) evaluate_model(v, MRS_long))) %>%
arrange(desc(AUC))
# 5. Test 3-Variable Combinations
cat("Evaluating 3-variable combinations...\n")
combos_3 <- combn(predictors, 3, simplify = FALSE)
results_3var <- bind_rows(lapply(combos_3, function(v) evaluate_model(v, MRS_long))) %>%
arrange(desc(AUC))
# 6. View the Results (Top 10 for each)
cat("\n--- Top 10 Single Predictors ---\n")
print(head(results_1var, 10))
cat("\n--- Top 10 Two-Variable Predictors ---\n")
print(head(results_2var, 10))
cat("\n--- Top 10 Three-Variable Predictors ---\n")
print(head(results_3var, 10))
library(dplyr)
library(tidyr)
library(pROC)
# 1. Create a consolidated dataset (Average when both exist, pull single if one is missing)
MRS_combined <- MRS_long %>%
rowwise() %>%
mutate(
cortical_thickness_base = mean(c(norm_cortical_thickness_dickerson_t_0, norm_cortical_thickness_dickerson_t_pre), na.rm = TRUE),
sum_hippocampus_base = mean(c(norm_sum_hippocampus_t_0, norm_sum_hippocampus_t_pre), na.rm = TRUE),
hippocampus_avg_act_base = mean(c(hippocampus_avg_act_t_0, hippocampus_avg_act_t_pre), na.rm = TRUE),
parietal_sup_l_act_base = mean(c(parietal_sup_l_act_t_0, parietal_sup_l_act_t_pre), na.rm = TRUE),
glu_precuneus_base = mean(c(glu_precuneus_t_0, glu_precuneus_t_pre), na.rm = TRUE),
glu_acc_base = mean(c(glu_acc_t_0, glu_acc_t_pre), na.rm = TRUE),
moca_score_total_base = mean(c(moca_score_total_30_t_0, moca_score_total_30_t_pre), na.rm = TRUE),
ptau217_base = mean(c(x99453_analyse_plasma_ptau217_t_0, x99453_analyse_plasma_ptau217_t_pre), na.rm = TRUE)
) %>%
ungroup() # Crucial: ungroups the data after rowwise calculations
# 2. Define the new consolidated predictors and target
target_var <- "decliners"
predictors <- c(
"cortical_thickness_base", "sum_hippocampus_base",
"hippocampus_avg_act_base", "parietal_sup_l_act_base",
"glu_precuneus_base", "glu_acc_base",
"moca_score_total_base", "ptau217_base"
)
# 3. Define the evaluation function
evaluate_model <- function(vars, data) {
formula_str <- paste(target_var, "~", paste(vars, collapse = " + "))
# Filter for complete cases on the specifically tested variables
df_clean <- data %>%
select(all_of(c(target_var, vars))) %>%
drop_na() %>%
filter(if_all(all_of(vars), ~ !is.nan(.))) # Specifically drops the NaN values generated by mean(NA, NA)
n_size <- nrow(df_clean)
if(n_size == 0 || length(unique(df_clean[[target_var]])) < 2) {
return(NULL)
}
model <- glm(as.formula(formula_str), data = df_clean, family = binomial)
pred_probs <- predict(model, type = "response")
roc_obj <- roc(df_clean[[target_var]], pred_probs, quiet = TRUE)
auc_val <- as.numeric(auc(roc_obj))
coords_best <- coords(roc_obj, "best", ret = c("specificity", "sensitivity"),
best.method = "youden", transpose = FALSE)
spec <- coords_best$specificity[1]
sens <- coords_best$sensitivity[1]
return(data.frame(
Model = paste(vars, collapse = " + "),
N = n_size,
AUC = round(auc_val, 4),
Sensitivity = round(sens, 4),
Specificity = round(spec, 4)
))
}
# 4. Run the Loops
cat("Evaluating single variables...\n")
results_1var <- bind_rows(lapply(predictors, function(v) evaluate_model(v, MRS_combined))) %>%
arrange(desc(AUC))
cat("Evaluating 2-variable combinations...\n")
combos_2 <- combn(predictors, 2, simplify = FALSE)
results_2var <- bind_rows(lapply(combos_2, function(v) evaluate_model(v, MRS_combined))) %>%
arrange(desc(AUC))
cat("Evaluating 3-variable combinations...\n")
combos_3 <- combn(predictors, 3, simplify = FALSE)
results_3var <- bind_rows(lapply(combos_3, function(v) evaluate_model(v, MRS_combined))) %>%
arrange(desc(AUC))
# 5. Output the Results
cat("\n--- Top Baseline Single Predictors ---\n")
print(head(results_1var, 10))
cat("\n--- Top Baseline Two-Variable Predictors ---\n")
print(head(results_2var, 10))
cat("\n--- Top Baseline Three-Variable Predictors ---\n")
print(head(results_3var, 10))
