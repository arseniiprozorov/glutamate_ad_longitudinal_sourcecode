structural_quadratic_model <- '
# Mediator
t2_hipp_e_tiv ~ a1 * t1_gl_prc_c
# Outcome (direct linear + quadratic + mediator)
slope_moca_scaled ~ cp1 * t1_gl_prc_c + cp2 * t1_gl_prc_sq +
b1  * t2_hipp_e_tiv
# Indirect effect via structural mediator
ind_structural := a1 * b1
'
fit_struct_quad_boot <- sem(
structural_quadratic_model,
data      = MRS_long,
missing   = "fiml",
fixed.x   = FALSE,
se        = "bootstrap",
bootstrap = 5000,        # 2000 is common; 5000 is more stable
test      = "bootstrap"  # ensures bootstrap-based p-values for params/tests
)
# Step 1: Model the mediator (Path a)
fit.mediator <- lm(t2_hipp_e_tiv ~ t1_glu_prec, data = MRS_long)
summary(fit.mediator)
# Step 2: Model the outcome (Paths b and c')
fit.outcome <- lm(hipp_l_diff_activation ~ t1_glu_prec + t2_hipp_e_tiv, data = MRS_long)
summary(fit.outcome)
# Step 3: Run the mediation analysis with 5000 bootstraps
med.out <- mediate(fit.mediator, fit.outcome, treat = "t1_glu_prec", mediator = "t2_hipp_e_tiv", boot = TRUE, sims = 5000)
vars <- c("t1_glu_prec", "t2_hipp_e_tiv", "slope_moca_scaled")
dat_med <- MRS_long[complete.cases(MRS_long[, vars]), vars]
fit.mediator <- lm(t2_hipp_e_tiv ~ t1_glu_prec, data = dat_med)
fit.outcome  <- lm(slope_moca_scaled ~ t1_glu_prec + t2_hipp_e_tiv, data = dat_med)
med.out <- mediate(
fit.mediator, fit.outcome,
treat    = "t1_glu_prec",
mediator = "t2_hipp_e_tiv",
boot     = TRUE,
sims     = 5000
)
summary(med.out)
## Mediation
library(mediation)
library(mediation)
fit_struct_quad_robust <- sem(
structural_quadratic_model,
data    = MRS_long,
missing = "fiml",
fixed.x = FALSE,
estimator = "MLR"   # robust SEs + scaled test statistic
)
summary(fit_struct_quad_robust, standardized = TRUE, ci = TRUE)
parameterEstimates(fit_struct_quad_robust, standardized = TRUE, ci = TRUE)
summary(lm(t2_hipp_e_tiv ~ t1_glu_prec, data = MRS_long))
summary(lm(t2_hipp_e_tiv ~ t1_glu_acc, data = MRS_long))
summary(lm(t2_cortical_thickness_dickson ~  t1_glu_prec, data = MRS_long))
summary(lm(t2_cortical_thickness_dickson  ~  t1_glu_acc, data = MRS_long))
library(lavaan)
# 1) Center ACC glutamate and create squared term (square the centered term)
MRS_long$t1_glu_acc_c  <- as.numeric(scale(MRS_long$t1_glu_acc, scale = FALSE))
MRS_long$t1_glu_acc_sq <- MRS_long$t1_glu_acc_c^2
# 2) Structural-only quadratic mediation model (ACC glutamate -> t2_hipp_e_tiv -> slope)
structural_quadratic_model_acc <- '
# Mediator
t2_hipp_e_tiv ~ a1 * t1_glu_acc_c
# Outcome (direct linear + quadratic + mediator)
slope_moca_scaled ~ cp1 * t1_glu_acc_c + cp2 * t1_glu_acc_sq +
b1  * t2_hipp_e_tiv
# Indirect effect
ind_structural := a1 * b1
'
# 3) Fit with FIML + robust SEs (no listwise deletion)
fit_struct_quad_acc_robust <- sem(
structural_quadratic_model_acc,
data      = MRS_long,
missing   = "fiml",
fixed.x   = FALSE,
estimator = "MLR"
)
summary(fit_struct_quad_acc_robust, standardized = TRUE, ci = TRUE)
parameterEstimates(fit_struct_quad_acc_robust, standardized = TRUE, ci = TRUE)
