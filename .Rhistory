facet_wrap(~Region) +
# Clean scientific theme
theme_classic(base_size = 14) +
scale_fill_manual(values = c("#66c2a5", "#fc8d62"),
labels = c("Non-Decliners", "Decliners")) +
labs(
title = "Regional Glutamate Change by Cognitive Status",
x = "Cognitive Decline Status",
y = "% Change in Glutamate",
fill = "Group"
) +
# Optional: Add a horizontal line at 0 to show no change
geom_hline(yintercept = 0, linetype = "dashed", alpha = 0.5)
