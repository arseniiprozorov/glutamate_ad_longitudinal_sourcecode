# Install lavaan if you don't have it yet: install.packages("lavaan")
library(lavaan)
# 1. Define the structural equation model syntax
med_syntax <- '
# Path a: X predicting the Mediator
glu_precuneus_T_0 ~ a * norm_sum_hippocampus_T_Pre
# Paths b and cprime: Predicting the Outcome
# (We include T_0 MoCA to maintain your rigorous autoregressive control)
moca_score_total_30_T_Post ~ b * glu_precuneus_T_0 + cp * norm_sum_hippocampus_T_Pre + moca_score_total_30_T_0
# Define the specific indirect and total effects
indirect_effect := a * b
direct_effect   := cp
total_effect    := cp + (a * b)
'
# 2. Fit the model using 1000 bootstrap iterations for stable p-values
set.seed(1234) # Ensures your bootstrap results are exactly reproducible
fit_mediation <- sem(model = med_syntax,
data = binned_cascade,
se = "bootstrap",
bootstrap = 1000)
# 3. Print the results leaderboard
print("=== TIMELINE-ANCHORED LONGITUDINAL MEDIATION RESULTS ===")
summary(fit_mediation, fit.measures = TRUE, standardized = TRUE, ci = TRUE)
