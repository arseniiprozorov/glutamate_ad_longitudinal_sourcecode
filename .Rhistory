select(participant_id, norm_sum_hippocampus, norm_cortical_thickness_dickerson) %>%
rename(
hipp_vol_T_minus1 = norm_sum_hippocampus,
thick_T_minus1 = norm_cortical_thickness_dickerson
)
# 2. Isolate metabolic/functional outcomes at T0
df_t0_outcomes <- MRS_relative_discrete %>%
filter(relative_visit == 0) %>%
select(participant_id, glu_precuneus, parietal_sup_l_act)
# 3. Merge into a clean retrospective frame
retro_frame <- inner_join(df_t_minus1, df_t0_outcomes, by = "participant_id")
# ---------------------------------------------------------
# 4. Run the Models
# ---------------------------------------------------------
# --- PREDICTING T0 GLUTAMATE ---
m_hipp_to_glu <- lm(glu_precuneus ~ hipp_vol_T_minus1, data = retro_frame)
m_thick_to_glu <- lm(glu_precuneus ~ thick_T_minus1, data = retro_frame)
print("=== RETROSPECTIVE MODELS: PREDICTING T0 GLUTAMATE ===")
print("--- Model A: T-1 Hippocampal Volume -> T0 Glutamate ---")
summary(m_hipp_to_glu)
print("--- Model B: T-1 Cortical Thickness -> T0 Glutamate ---")
summary(m_thick_to_glu)
# --- PREDICTING T0 FUNCTIONAL ACTIVATION ---
m_hipp_to_act <- lm(parietal_sup_l_act ~ hipp_vol_T_minus1, data = retro_frame)
m_thick_to_act <- lm(parietal_sup_l_act ~ thick_T_minus1, data = retro_frame)
print("=== RETROSPECTIVE MODELS: PREDICTING T0 FUNCTIONAL ACTIVATION ===")
print("--- Model C: T-1 Hippocampal Volume -> T0 Parietal Activation ---")
summary(m_hipp_to_act)
print("--- Model D: T-1 Cortical Thickness -> T0 Parietal Activation ---")
summary(m_thick_to_act)
library(dplyr)
library(tidyr)
# ---------------------------------------------------------
# Step 1: Reshape data to wide format for T-1, T0, and T+1
# ---------------------------------------------------------
analysis_wide_3pt <- MRS_relative_discrete %>%
filter(relative_visit %in% c(-1, 0, 1)) %>%
mutate(timepoint = case_when(
relative_visit == -1 ~ "Tm1",
relative_visit == 0  ~ "T0",
relative_visit == 1  ~ "Tp1"
)) %>%
select(participant_id, timepoint, x99453_analyse_plasma_ptau217, moca_score_total_30,
norm_cortical_thickness_dickerson, norm_sum_hippocampus,
hippocampus_avg_act, parietal_sup_l_act, glu_precuneus, glu_acc) %>%
pivot_wider(
id_cols = participant_id,
names_from = timepoint,
values_from = c(x99453_analyse_plasma_ptau217, moca_score_total_30,
norm_cortical_thickness_dickerson, norm_sum_hippocampus,
hippocampus_avg_act, parietal_sup_l_act, glu_precuneus, glu_acc),
names_glue = "{.value}_{timepoint}"
)
# ---------------------------------------------------------
# Step 2: Define variable sets per timepoint
# ---------------------------------------------------------
vars_Tm1 <- c("x99453_analyse_plasma_ptau217_Tm1", "moca_score_total_30_Tm1",
"norm_cortical_thickness_dickerson_Tm1", "norm_sum_hippocampus_Tm1",
"hippocampus_avg_act_Tm1", "parietal_sup_l_act_Tm1")
vars_T0  = c("x99453_analyse_plasma_ptau217_T0", "moca_score_total_30_T0",
"norm_cortical_thickness_dickerson_T0", "norm_sum_hippocampus_T0",
"hippocampus_avg_act_T0", "parietal_sup_l_act_T0",
"glu_precuneus_T0", "glu_acc_T0")
vars_Tp1 <- c("x99453_analyse_plasma_ptau217_Tp1", "moca_score_total_30_Tp1",
"norm_cortical_thickness_dickerson_Tp1", "norm_sum_hippocampus_Tp1",
"hippocampus_avg_act_Tp1", "parietal_sup_l_act_Tp1",
"glu_precuneus_Tp1", "glu_acc_Tp1")
# ---------------------------------------------------------
# Step 3: Define the combinatorial screening engine
# ---------------------------------------------------------
screen_combinations <- function(predictors, outcomes, data_frame, loop_name) {
master_results <- data.frame()
for (pred in predictors) {
for (out in outcomes) {
paired_data <- data_frame %>% select(all_of(c(pred, out))) %>% drop_na()
n_available <- nrow(paired_data)
if (n_available >= 8) {
formula_str <- paste(out, "~", pred)
fit <- lm(as.formula(formula_str), data = data_frame)
fit_sum <- summary(fit)
if (nrow(fit_sum$coefficients) > 1) {
master_results <- rbind(master_results, data.frame(
Analysis_Loop = loop_name,
Predictor     = pred,
Outcome       = out,
Sample_N      = n_available,
Beta_Estimate = fit_sum$coefficients[2, 1],
t_value       = fit_sum$coefficients[2, 3],
p_value       = fit_sum$coefficients[2, 4],
R_Squared     = fit_sum$r.squared,
stringsAsFactors = FALSE
))
}
}
}
}
return(master_results)
}
# ---------------------------------------------------------
# Step 4: Run loops across the 3-point horizons
# ---------------------------------------------------------
results_step1 <- screen_combinations(vars_Tm1, vars_T0,  analysis_wide_3pt, "1. Origins (T-1 to T0)")
results_step2 <- screen_combinations(vars_T0,  vars_Tp1, analysis_wide_3pt, "2. Downstream (T0 to T+1)")
results_step3 <- screen_combinations(vars_Tm1, vars_Tp1, analysis_wide_3pt, "3. Extended (T-1 to T+1)")
all_3pt_pathways <- bind_rows(results_step1, results_step2, results_step3)
# ---------------------------------------------------------
# Step 5: Print clean significant and trend leaderboards
# ---------------------------------------------------------
significant_paths_3pt <- all_3pt_pathways %>%
filter(p_value <= 0.05) %>%
arrange(p_value)
marginal_paths_3pt <- all_3pt_pathways %>%
filter(p_value > 0.05 & p_value <= 0.10) %>%
arrange(p_value)
print("==== 3-POINT SIGNIFICANT PATHWAYS (p <= 0.05) ====")
if(nrow(significant_paths_3pt) > 0) { print(as.data.frame(significant_paths_3pt)) } else { print("No paths reached absolute significance.") }
print("==== 3-POINT MARGINAL TRENDS (0.05 < p <= 0.10) ====")
if(nrow(marginal_paths_3pt) > 0) { print(as.data.frame(marginal_paths_3pt)) } else { print("No marginal trends detected.") }
library(dplyr)
library(tidyr)
# ---------------------------------------------------------
# Step 1: Group the relative timeline and average adjacent visits
# ---------------------------------------------------------
binned_cascade <- MRS_relative_discrete %>%
filter(relative_visit >= -2 & relative_visit <= 2) %>%
mutate(
sequence_window = case_when(
relative_visit %in% c(-2, -1) ~ "T_Pre",
relative_visit == 0           ~ "T_0",
relative_visit %in% c(1, 2)   ~ "T_Post"
)
) %>%
group_by(participant_id, sequence_window) %>%
# Average the values for participants with multiple scans in a window
summarise(across(c(norm_cortical_thickness_dickerson,
norm_sum_hippocampus,
hippocampus_avg_act,
parietal_sup_l_act,
glu_precuneus,
glu_acc,
moca_score_total_30),
~ mean(., na.rm = TRUE)), .groups = "drop") %>%
# Clean up NaN values created by averaging NAs
mutate(across(where(is.numeric), ~ ifelse(is.nan(.), NA, .))) %>%
# ---------------------------------------------------------
# Step 2: Reshape to wide format for direct linear regressions
# ---------------------------------------------------------
pivot_wider(
names_from = sequence_window,
values_from = c(norm_cortical_thickness_dickerson,
norm_sum_hippocampus,
hippocampus_avg_act,
parietal_sup_l_act,
glu_precuneus,
glu_acc,
moca_score_total_30)
)
# ---------------------------------------------------------
# Step 3: Run the Core Sequence Models
# ---------------------------------------------------------
print("=== ACT I: UPSTREAM (T_Pre Structure -> T_0 Metabolism & Activation) ===")
# Does historical cortical thickness dictate the index baseline?
print("--- T_Pre Cortical Thickness -> T_0 Glutamate ---")
summary(lm(glu_precuneus_T_0 ~ norm_cortical_thickness_dickerson_T_Pre, data = binned_cascade))
print("--- T_Pre Cortical Thickness -> T_0 Parietal Activation ---")
summary(lm(parietal_sup_l_act_T_0 ~ norm_cortical_thickness_dickerson_T_Pre, data = binned_cascade))
# Does historical hippocampal volume dictate the index baseline?
print("--- T_Pre Hippocampal Volume -> T_0 Glutamate ---")
summary(lm(glu_precuneus_T_0 ~ norm_sum_hippocampus_T_Pre, data = binned_cascade))
print("--- T_Pre Hippocampal Volume -> T_0 Hippocampal Activation ---")
summary(lm(hippocampus_avg_act_T_0 ~ norm_sum_hippocampus_T_Pre, data = binned_cascade))
print("=== ACT II: DOWNSTREAM (T_0 Metabolism -> T_Post Structure, Activation & Cognition) ===")
# Does the index glutamate surge protect future structure?
print("--- T_0 Glutamate -> T_Post Cortical Thickness ---")
summary(lm(norm_cortical_thickness_dickerson_T_Post ~ glu_precuneus_T_0, data = binned_cascade))
print("--- T_0 Glutamate -> T_Post Hippocampal Volume ---")
summary(lm(norm_sum_hippocampus_T_Post ~ glu_precuneus_T_0, data = binned_cascade))
# Does the index glutamate surge predict future functional network states?
print("--- T_0 Glutamate -> T_Post Parietal Activation ---")
summary(lm(parietal_sup_l_act_T_Post ~ glu_precuneus_T_0, data = binned_cascade))
print("--- T_0 Glutamate -> T_Post Hippocampal Activation ---")
summary(lm(hippocampus_avg_act_T_Post ~ glu_precuneus_T_0, data = binned_cascade))
# Does the index glutamate surge preserve global cognition?
print("--- T_0 Glutamate -> T_Post MoCA Total ---")
summary(lm(moca_score_total_30_T_Post ~ glu_precuneus_T_0, data = binned_cascade))
summary(lm(norm_sum_hippocampus_T_Post ~ glu_precuneus_T_0 + norm_sum_hippocampus_T_Pre, data = binned_cascade))
