summary(model_ptau217_acc)
roc_ptau217_acc <- roc(model_ptau217_acc$y, fitted(model_ptau217_acc))
auc(roc_ptau217_acc)
coords(roc_ptau217_acc, "best", ret=c("threshold", "specificity", "sensitivity"), best.method="youden")
