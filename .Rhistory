###################### Analyses ####################
names(MRS_long)
#LMM#
library(lmerTest)
model_glu_prec <- lmer( glu_precuneus ~ visit * diagnostic_nick + age + sex + education + (1 | participant_id),
data = MRS_long)
summary(model_glu_prec)
model_glu_acc <- lmer( glu_acc ~ visit * diagnostic_nick + age + sex + education + (1 | participant_id),
data = MRS_long)
summary(model_glu_acc)
# Convert "t02" string into the number 2
MRS_long$visit_num <- as.numeric(gsub("t", "", MRS_long$visit))
library(lmerTest)
# 1. Define your specific 11 targeted variables
long_vars <- c(
"moca_score_total_30",
"glu_precuneus",
"glu_acc",
"norm_sum_hippocampus",
"norm_cortical_thickness_dickerson",
"cortical_thickness_dickerson",
"hippocampus_avg_act",
"hippocampus_l_act",
"parietal_sup_l_act",
"parietal_sup_r_act",
"precuneus_l_act"
)
# 2. Create an empty data frame for the results
pairwise_results <- data.frame(
Outcome = character(),
Predictor = character(),
Estimate = numeric(),
P_Value_Raw = numeric(),
stringsAsFactors = FALSE
)
# 3. Loop through combinations, avoiding self-correlations
for (outcome in long_vars) {
for (predictor in long_vars) {
if (outcome != predictor) {
# Build the formula: Does the predictor track with the outcome over time?
form <- as.formula(paste(outcome, "~", predictor, "+ age + sex + education + (1 | participant_id)"))
model <- try(lmer(form, data = MRS_long), silent = TRUE)
if (!inherits(model, "try-error")) {
coef_table <- summary(model)$coefficients
# Extract the relationship
if (predictor %in% rownames(coef_table)) {
est <- coef_table[predictor, "Estimate"]
p_val <- coef_table[predictor, "Pr(>|t|)"]
pairwise_results <- rbind(pairwise_results, data.frame(
Outcome = outcome,
Predictor = predictor,
Estimate = est,
P_Value_Raw = p_val
))
}
}
}
}
}
# 4. Apply a targeted FDR correction for the pairwise comparisons
pairwise_results$P_Value_FDR <- p.adjust(pairwise_results$P_Value_Raw, method = "fdr")
significant_hits <- subset(pairwise_results, P_Value_FDR < 0.05)
# 5. Clean and view the significant relationships
significant_hits[, 3:5] <- round(significant_hits[, 3:5], 3)
print(significant_hits)
