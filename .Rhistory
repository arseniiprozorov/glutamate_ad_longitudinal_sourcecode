"parietal_sup_l_act",
"parietal_sup_r_act",
"precuneus_l_act"
)
# 2. Storage dataframe
quad_trend_results <- data.frame(
Variable = character(),
Quad_Estimate = numeric(),
P_Value_Raw = numeric(),
stringsAsFactors = FALSE
)
# 3. Run the loop
for (var in vars_to_test) {
# Formula: testing for both linear and quadratic components
# We test the p-value of the quadratic term specifically
form <- as.formula(paste(var, "~ visit_num + I(visit_num^2) + age + sex + education + (1 | participant_id)"))
model <- try(lmer(form, data = MRS_long), silent = TRUE)
if (!inherits(model, "try-error")) {
coef_table <- summary(model)$coefficients
# Extract the effect of I(visit_num^2)
if ("I(visit_num^2)" %in% rownames(coef_table)) {
est <- coef_table["I(visit_num^2)", "Estimate"]
p_val <- coef_table["I(visit_num^2)", "Pr(>|t|)"]
quad_trend_results <- rbind(quad_trend_results, data.frame(
Variable = var,
Quad_Estimate = est,
P_Value_Raw = p_val
))
}
}
}
# 4. Apply FDR Correction
quad_trend_results$P_Value_FDR <- p.adjust(quad_trend_results$P_Value_Raw, method = "fdr")
# 5. Clean and sort
quad_trend_results <- quad_trend_results[order(quad_trend_results$P_Value_FDR), ]
quad_trend_results[, 2:4] <- round(quad_trend_results[, 2:4], 3)
print(quad_trend_results)
# Create the continuous "Age at Visit" variable
# (If your data is already long, this adds the time elapsed to baseline age)
MRS_long$age_at_visit <- MRS_long$t1_age + MRS_long$years_elapsed
# New Batch Script using Age as the time metric
vars_to_test <- c("moca_score_total_30", "glu_precuneus", "glu_acc", "norm_sum_hippocampus", "norm_cortical_thickness_dickerson")
trend_results_age <- data.frame(Variable = character(), Slope_Estimate = numeric(), P_Value_Raw = numeric())
for (var in vars_to_test) {
# Formula: Trajectory measured by Age
# We still include Sex and Education as fixed covariates
form <- as.formula(paste(var, "~ age_at_visit + sex + education + (1 | participant_id)"))
model <- try(lmer(form, data = MRS_long), silent = TRUE)
if (!inherits(model, "try-error")) {
coef_table <- summary(model)$coefficients
if ("age_at_visit" %in% rownames(coef_table)) {
trend_results_age <- rbind(trend_results_age, data.frame(
Variable = var,
Slope_Estimate = coef_table["age_at_visit", "Estimate"],
P_Value_Raw = coef_table["age_at_visit", "Pr(>|t|)"]
))
}
}
}
# Correct and Print
trend_results_age$P_Value_FDR <- p.adjust(trend_results_age$P_Value_Raw, method = "fdr")
print(trend_results_age)
