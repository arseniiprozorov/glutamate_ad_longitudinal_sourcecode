# We will combine these with the 'decliners' outcome and the 'covariates'
model_formulas <- c(
"decliner_regression ~ plasma_ptau217_z + m_m_acc_z",                       # 1
"decliner_regression ~ plasma_ptau217_z + m_m_precuneus_z",                 # 2
"decliner_regression ~ m_m_precuneus_z + cortical_thickness_adsignature_dickson_z", # 7
"decliner_regression ~ m_m_acc_z + cortical_thickness_adsignature_dickson_z",       # 8
"decliner_regression ~ m_m_precuneus_z + hipp_mean_z",                      # 9
"decliner_regression ~ m_m_acc_z + hipp_mean_z",                            # 10
"decliner_regression ~ m_m_precuneus_z + activation_parietal_sup_l_z",      # 3
"decliner_regression ~ m_m_acc_z + activation_parietal_sup_l_z",            # 4
"decliner_regression ~ m_m_precuneus_z + hipp_mean_act_z",                  # 5
"decliner_regression ~ m_m_acc_z + hipp_mean_act_z",                        # 6
"decliner_regression ~ m_m_precuneus_z + m_m_acc_z"                         # 11
)
# Loop through all models
results_list <- list()
for (f in model_formulas) {
full_formula <- paste0(f, covariates)
# Run the Robust Bayesian Model
fit <- bayesglm(as.formula(full_formula), data = MRS_prediction, family = binomial(link = "logit"))
# Extract metrics
probs <- predict(fit, type = "response")
actuals <- model.frame(fit)$decliners
roc_obj <- roc(actuals, probs, quiet = TRUE)
# Store results
results_list[[f]] <- list(
model = summary(fit),
auc = auc(roc_obj),
youden = coords(roc_obj, "best", ret=c("threshold", "specificity", "sensitivity"), best.method="youden")
)
# Print progress
cat("--------------------------------------------------\n")
