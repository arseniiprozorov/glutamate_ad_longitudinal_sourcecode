mutate(Relationship = "ACC Glutamate vs. Hippocampal Volume")
df_acc_thick <- MRS_long %>%
select(pscid, diagnostic_nick, x_val = t1_glu_acc, y_val = t2_cortical_thickness_dickson) %>%
mutate(Relationship = "ACC Glutamate vs. Cortical Thickness")
# -- Precuneus Pairs --
df_prec_hipp <- MRS_long %>%
select(pscid, diagnostic_nick, x_val = t1_glu_prec, y_val = t2_hipp_e_tiv) %>%
mutate(Relationship = "Precuneus Glutamate vs. Hippocampal Volume")
df_prec_thick <- MRS_long %>%
select(pscid, diagnostic_nick, x_val = t1_glu_prec, y_val = t2_cortical_thickness_dickson) %>%
mutate(Relationship = "Precuneus Glutamate vs. Cortical Thickness")
# Combine all 4 into one dataframe
plot_data_struct <- bind_rows(df_acc_hipp, df_acc_thick, df_prec_hipp, df_prec_thick) %>%
# Ensure the diagnostic groups are ordered correctly
mutate(diagnostic_nick = factor(diagnostic_nick, levels = c("HC", "SCD+", "MCI")))
# 2. Create the OVERALL regression plot with 4 facets
ggplot(plot_data_struct, aes(x = x_val, y = y_val)) +
# KEEP dots colored by diagnosis
geom_point(aes(color = diagnostic_nick), alpha = 0.6, size = 2.5) +
# ONE overall regression line for the whole sample
geom_smooth(method = "lm", color = "black", fill = "gray70", alpha = 0.3, linewidth = 1.2) +
# Facet by the 4 relationships. ncol = 2 makes it a neat 2x2 grid.
facet_wrap(~ Relationship, scales = "free", ncol = 2) +
# Styling
scale_color_manual(values = c("HC" = "#3B5998", "SCD+" = "#E69F00", "MCI" = "#D55E00")) +
labs(
title = "Overall Associations: Baseline Glutamate vs. Follow-up Brain Structure",
subtitle = "Whole-sample regression lines across all regional combinations",
x = "Baseline Glutamate Concentration (mM)",
y = "Structural Metric (Volume or Thickness)",
color = "Diagnosis"
) +
theme_minimal() +
theme(
panel.grid.minor = element_blank(),
strip.text = element_text(size = 11, face = "bold"),
strip.background = element_rect(fill = "gray95", color = NA)
)
# Split the dataset by diagnosis
data_by_group <- split(MRS_long, MRS_long$diagnostic_nick)
# 1. ACC vs Hippocampus Models
cat("\n--- ACC Glutamate vs Hippocampus ---\n")
hipp_models <- lapply(data_by_group, function(df) {
lm(t2_hipp_e_tiv ~ t1_glu_acc + t1_age + sexe, data = df)
})
# Print the summary for each group
lapply(hipp_models, summary)
# 2. Precuneus vs Cortical Thickness Models
cat("\n--- Precuneus Glutamate vs Cortical Thickness ---\n")
thick_models <- lapply(data_by_group, function(df) {
lm(t2_cortical_thickness_dickson ~ t1_glu_prec + t1_age + sexe, data = df)
})
# Print the summary for each group
lapply(thick_models, summary)
