# Y ~ X + M
model_y_comb <- lm(comp_act_t1 ~ comp_struct_t1 + comp_glu_t1, data = MRS_long)
summary(model_y_comb)
# Mediate
med_comb <- mediate(model_m_comb, model_y_comb,
treat = "mean_structure", mediator = "mean_glu",
boot = TRUE, sims = 1000)
