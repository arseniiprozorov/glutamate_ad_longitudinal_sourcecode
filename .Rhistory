MRS_long$parietal_sup_r_act <- winsorize_iqr(MRS_long$parietal_sup_r_act, 1.5)
MRS_long$parietal_sup_avg_act <- winsorize_iqr(MRS_long$parietal_sup_avg_act, 1.5)
