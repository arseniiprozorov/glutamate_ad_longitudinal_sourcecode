logistic_decliners_t1acc <- glm(decliners ~ t1_glu_acc, data = MRS_clean, family = binomial)
predicted_decliners_t1acc <- predict(logistic_decliners_t1acc, type = "response")
logistic_decliners_t1prec <- glm(decliners ~ t1_glu_prec, data = MRS_clean, family = binomial)
predicted_decliners_t1prec <- predict(logistic_decliners_t1prec, type = "response")
logistic_decliners_t1glu <- glm(decliners ~ t1_glu_prec + t1_glu_acc, data = MRS_clean, family = binomial)
predicted_decliners_t1glu <- predict(logistic_decliners_t1glu, type = "response")
# 3. Now build your ROC curves (no errors because the dataset has no missing rows)
roc_acc <- roc(response = MRS_clean$decliners, predictor = predicted_decliners_t1acc)
roc_prec <- roc(response = MRS_clean$decliners, predictor = predicted_decliners_t1prec)
roc_combined <- roc(response = MRS_clean$decliners, predictor = predicted_decliners_t1glu)
