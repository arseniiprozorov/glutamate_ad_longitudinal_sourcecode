model_spec <- best_coords$specificity[1]
model_sens <- best_coords$sensitivity[1]
# 7. Append the results
results_loocv <- rbind(results_loocv, data.frame(
Model = vars,
LOOCV_AUC = round(loocv_auc, 3),
LOOCV_Sensitivity = round(model_sens, 3),
LOOCV_Specificity = round(model_spec, 3),
N_Obs = n_obs,
N_Decliners = n_decliners
))
}
# 8. Sort by the highest Cross-Validated AUC
top_loocv_models <- results_loocv %>% arrange(desc(LOOCV_AUC))
# 9. Print the honest leaderboard
print("=== TOP PREDICTIVE MODELS (LEAVE-ONE-OUT CROSS-VALIDATED) ===")
print(head(top_loocv_models, 10))
library(pROC)
library(dplyr)
# 1. Define all your standardized candidate biomarkers
biomarkers <- c("plasma_ptau217_z",
"m_m_precuneus_z",
"m_m_acc_z",
"hipp_mean_z",
"cortical_thickness_adsignature_dickson_z",
"hipp_mean_act_z",
"activation_parietal_sup_l_z")
# 2. Generate all unique 2-variable combinations
combinations <- combn(biomarkers, 2, simplify = FALSE)
# 3. Create an empty dataframe to store the expanded performance metrics
results_df <- data.frame(Model = character(),
AUC = numeric(),
Sensitivity = numeric(),
Specificity = numeric(),
AIC = numeric(),
N_Obs = numeric(),
N_Decliners = numeric(),
stringsAsFactors = FALSE)
# 4. Loop through every pairing, build the model, and extract the stats
for (combo in combinations) {
var1 <- combo[1]
var2 <- combo[2]
# Build the mathematical formula
fmla <- as.formula(paste("decliners ~", var1, "+", var2))
# Run the logistic regression model
model_fit <- tryCatch({
glm(fmla, data = MRS_prediction, family = "binomial")
}, error = function(e) return(NULL))
if (!is.null(model_fit)) {
# Extract the true Y outcomes (0s and 1s) used in this specific model
y_actual <- model_fit$y
y_pred <- fitted(model_fit)
# Calculate the exact number of decliners (where Y == 1) in this subset
n_decliners <- sum(y_actual == 1)
# Calculate AUC
roc_obj <- roc(y_actual, y_pred, quiet = TRUE, levels = c(0, 1), direction = "<")
model_auc <- as.numeric(auc(roc_obj))
# Extract Optimal Sensitivity and Specificity (using Youden's Index)
# transpose = FALSE ensures a clean dataframe output from pROC
best_coords <- coords(roc_obj, "best", ret = c("specificity", "sensitivity"),
best.method = "youden", transpose = FALSE)
# In rare cases, multiple thresholds tie for "best". We extract the first one [1].
model_spec <- best_coords$specificity[1]
model_sens <- best_coords$sensitivity[1]
# Extract AIC and Sample Size
model_aic <- AIC(model_fit)
n_obs <- nobs(model_fit)
# Append the results to our tracking table
results_df <- rbind(results_df, data.frame(
Model = paste(var1, "+", var2),
AUC = round(model_auc, 3),
Sensitivity = round(model_sens, 3),
Specificity = round(model_spec, 3),
AIC = round(model_aic, 1),
N_Obs = n_obs,
N_Decliners = n_decliners
))
}
}
# 5. Sort the results to find the "Best" models (Highest AUC first)
top_models <- results_df %>% arrange(desc(AUC))
# 6. Print the top 10 pairwise combinations
print("=== TOP 2-VARIABLE PREDICTIVE MODELS ===")
print(head(top_models, 20))
library(pROC)
library(dplyr)
# 1. Define all your standardized candidate biomarkers
biomarkers <- c("plasma_ptau217_z",
"m_m_precuneus_z",
"m_m_acc_z",
"hipp_mean_z",
"cortical_thickness_adsignature_dickson_z",
"hipp_mean_act_z",
"activation_parietal_sup_l_z")
# 2. Generate all unique 2-variable combinations
combinations <- combn(biomarkers, 2, simplify = FALSE)
# 3. Create an empty dataframe to store the LOOCV metrics
results_loocv_2var <- data.frame(Model = character(),
LOOCV_AUC = numeric(),
LOOCV_Sensitivity = numeric(),
LOOCV_Specificity = numeric(),
N_Obs = numeric(),
N_Decliners = numeric(),
stringsAsFactors = FALSE)
# 4. Loop through every 2-variable pairing
for (combo in combinations) {
# Build the formula string for the 2 variables
vars <- paste(combo, collapse = " + ")
fmla <- as.formula(paste("decliners ~", vars))
# Isolate exact subset and drop missing rows to keep sample size constant across folds
model_data <- MRS_prediction %>%
select(decliners, all_of(combo)) %>%
na.omit()
n_obs <- nrow(model_data)
n_decliners <- sum(model_data$decliners == 1)
# Safety check: Skip models that crashed due to massive missing data
if(n_obs < 20 || n_decliners < 5) next
# Initialize an empty vector to hold the out-of-fold predictions
loocv_preds <- numeric(n_obs)
# 5. Execute the Leave-One-Out Loop
for(i in 1:n_obs) {
train_data <- model_data[-i, ]
test_data <- model_data[i, , drop = FALSE]
# Fit the model on the training fold
fit <- suppressWarnings(glm(fmla, data = train_data, family = "binomial"))
# Predict the probability for the left-out patient
loocv_preds[i] <- predict(fit, newdata = test_data, type = "response")
}
# 6. Calculate the true, cross-validated AUC using the out-of-fold predictions
roc_obj <- suppressMessages(roc(model_data$decliners, loocv_preds, quiet = TRUE, levels = c(0, 1), direction = "<"))
loocv_auc <- as.numeric(auc(roc_obj))
# Extract Out-of-Sample Sensitivity and Specificity
best_coords <- coords(roc_obj, "best", ret = c("specificity", "sensitivity"),
best.method = "youden", transpose = FALSE)
model_spec <- best_coords$specificity[1]
model_sens <- best_coords$sensitivity[1]
# 7. Append the results
results_loocv_2var <- rbind(results_loocv_2var, data.frame(
Model = vars,
LOOCV_AUC = round(loocv_auc, 3),
LOOCV_Sensitivity = round(model_sens, 3),
LOOCV_Specificity = round(model_spec, 3),
N_Obs = n_obs,
N_Decliners = n_decliners
))
}
# 8. Sort by the highest Cross-Validated AUC
top_loocv_2var <- results_loocv_2var %>% arrange(desc(LOOCV_AUC))
# 9. Print the honest leaderboard
print("=== TOP 2-VARIABLE PREDICTIVE MODELS (LOOCV) ===")
print(head(top_loocv_2var, 20))
